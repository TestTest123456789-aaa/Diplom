<Page x:Class="BPRapp.Pages.MainMenuAdmins.ExportImport.ExportImport"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Экспорт/Импорт данных">

    <Page.Resources>
        <!-- 🎨 Корпоративные цвета -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>
        <Color x:Key="AccentBlue">#4A86C7</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>

        <!-- ✨ Тень для карточек -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" 
                          Color="#333333" Opacity="0.15" Direction="315"/>

        <!-- 🔘 Стиль кнопки меню -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="{StaticResource LightBlueBrush}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource LightBlueBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 📦 Стиль для блоков настроек -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- 🏷️ Стиль заголовка секции -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Page.Resources>

    <!-- 🎨 Градиентный фон -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource LightBlue}" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔷 Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="White" CornerRadius="24" Width="48" Height="48"
                        HorizontalAlignment="Left" Effect="{StaticResource CardShadow}">
                    <TextBlock Text="📤" FontSize="26" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Экспорт / Импорт данных" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="КГПАОУ Авиационный техникум имени А.Д. Швецова"
                               FontSize="12" Foreground="#E6F2FF" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 📋 Основное содержимое -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: Меню -->
            <Border Grid.Column="0" Background="White" CornerRadius="12"
                    Padding="15" Effect="{StaticResource CardShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="📌 Разделы" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,15"/>
                        <Button Content="🔐 Администраторы" Click="OpenAdmins_List" Style="{StaticResource MenuButton}"/>
                        <Button Content="👨‍🏫 Преподаватели" Click="OpenTeachers_List" Style="{StaticResource MenuButton}"/>
                        <Button Content="📤 Экспорт/Импорт" Click="OpenExportImport" Style="{StaticResource MenuButton}"
                                Background="{StaticResource LightBlueBrush}" BorderBrush="{StaticResource PrimaryBlueBrush}"/>
                        <Separator Margin="5,10" Background="{StaticResource LightBlueBrush}"/>
                        <Button Content="🚪 Выйти из системы" Click="OpenAuthorization"
                                Width="190" Height="45" Margin="5,5,5,15">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MenuButton}">
                                    <Setter Property="Background" Value="#FFE5E5"/>
                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFCDD2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Правая панель: Функционал -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="20,0,0,0">
                <StackPanel>
                    <TextBlock Text="Выберите действие:" Style="{StaticResource SectionLabel}"/>

                    <!-- 🔹 Экспорт в Excel -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="📊 Экспорт в Excel" Style="{StaticResource SectionLabel}" FontSize="16"/>
                            <TextBlock Text="Скачайте список всех преподавателей в формате .xlsx"
                                       Foreground="Gray" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            <Button Content="📥 Скачать Excel-файл" Click="ExportToExcel"
                                    Background="{StaticResource PrimaryBlueBrush}" Foreground="White" 
                                    Height="40" FontWeight="Bold" Cursor="Hand" Width="200" HorizontalAlignment="Left">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource DarkBlueBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 🔹 Импорт из Excel -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="📤 Импорт из Excel" Style="{StaticResource SectionLabel}" FontSize="16"/>
                            <TextBlock Text="Загрузите преподавателей из Excel-файла (шаблон ниже)"
                                       Foreground="Gray" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="📁 Выбрать файл" Click="ImportFromExcel"
                                        Background="{StaticResource PrimaryBlueBrush}" Foreground="White"
                                        Width="150" Height="35" Margin="0,0,10,0"/>
                                <Button Content="⬇️ Скачать шаблон" Click="DownloadTemplate"
                                        Background="White" Foreground="{StaticResource PrimaryBlueBrush}"
                                        BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="1"
                                        Width="150" Height="35"/>
                            </StackPanel>
                            <TextBlock x:Name="importStatusTB" Foreground="{StaticResource DarkBlueBrush}"
                                       TextWrapping="Wrap" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- 🔹 Экспорт в 1C XML -->
                    <Border Style="{StaticResource SectionCard}" Background="#F0F8FF" BorderBrush="#4682B4">
                        <StackPanel>
                            <TextBlock Text="🔄 Экспорт в 1C (XML)" Style="{StaticResource SectionLabel}" 
                                       FontSize="16" Foreground="#4682B4"/>
                            <TextBlock Text="Совместимый формат для интеграции с 1C:Предприятие"
                                       Foreground="Gray" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            <Button Content="📤 Экспортировать в XML" Click="ExportTo1C"
                                    Background="#4682B4" Foreground="White" Height="35" Width="200" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- 🔹 Справка -->
                    <Expander Header="ℹ️ Формат файла 1C (XML)" Margin="0,0,0,20"
                              Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1">
                        <TextBox IsReadOnly="True" Height="120" TextWrapping="Wrap"
                                 FontFamily="Consolas" FontSize="10" Background="White"
                                 Text="&lt;?xml version=&quot;1.0&quot; encoding=&quot;utf-8&quot;?&gt;&#10;&lt;Teachers&gt;&#10;  &lt;Teacher&gt;&#10;    &lt;FIO&gt;Иванов Иван Иванович&lt;/FIO&gt;&#10;    &lt;Login&gt;ivanov&lt;/Login&gt;&#10;    &lt;Email&gt;ivanov@school.ru&lt;/Email&gt;&#10;    &lt;Phone&gt;89001234567&lt;/Phone&gt;&#10;  &lt;/Teacher&gt;&#10;&lt;/Teachers&gt;"/>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>