<Page x:Class="BPRapp.Pages.MainMenuAdmins.ExportImport.ExportImport"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuAdmins.ExportImport"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Экспорт/Импорт">

    <Grid>
        <!-- Заголовок -->
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="📤 Экспорт / 📥 Импорт данных" Foreground="White" 
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" 
                   FontSize="19" FontFamily="MV Boli"/>
        </Grid>

        <Grid Margin="0,45,0,0" Background="White">
            <!-- Боковая панель -->
            <Grid Width="3" Margin="200,0,0,0" Background="CadetBlue" HorizontalAlignment="Left"/>

            <!-- Меню навигации -->
            <ScrollViewer Margin="0, 0, 0, 40" HorizontalAlignment="Left" Width="200" BorderBrush="White">
                <StackPanel Background="White">
                    <Button Content="🔐 Администраторы" HorizontalAlignment="Center" Click="OpenAdmins_List" 
                            Foreground="White" Width="170" Height="30" Background="CadetBlue" 
                            BorderBrush="Black" BorderThickness="1" Margin="5"/>
                    <Button Content="👨‍🏫 Преподаватели" HorizontalAlignment="Center" Click="OpenTeachers_List" 
                            Foreground="White" Width="170" Height="30" Background="CadetBlue" 
                            BorderBrush="Black" BorderThickness="1" Margin="5"/>
                    <Button Content="📤 Экспорт/Импорт" HorizontalAlignment="Center" Click="OpenExportImport" 
                            Foreground="White" Width="170" Height="30" Background="#2E8B57" 
                            BorderBrush="Black" BorderThickness="1" Margin="5" FontWeight="Bold"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Основной контент -->
            <ScrollViewer Margin="210, 20, 20, 40" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- 🔹 Блок: Экспорт в Excel -->
                    <Border BorderBrush="CadetBlue" BorderThickness="1" CornerRadius="10" 
                            Background="#F8FBFF" Margin="0,0,0,20" Padding="15">
                        <StackPanel>
                            <TextBlock Text="📊 Экспорт в Excel" FontWeight="Bold" FontSize="16" 
                                       Foreground="#2E8B57" Margin="0,0,0,10"/>
                            <TextBlock Text="Скачайте список всех преподавателей в формате .xlsx" 
                                       Foreground="Gray" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            <Button Content="📥 Скачать Excel-файл" Click="ExportToExcel" 
                                    Background="#2E8B57" Foreground="White" Height="40" 
                                    FontWeight="Bold" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#2E8B57"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#257346"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 🔹 Блок: Импорт из Excel -->
                    <Border BorderBrush="CadetBlue" BorderThickness="1" CornerRadius="10" 
                            Background="#F8FBFF" Margin="0,0,0,20" Padding="15">
                        <StackPanel>
                            <TextBlock Text="📤 Импорт из Excel" FontWeight="Bold" FontSize="16" 
                                       Foreground="#2E8B57" Margin="0,0,0,10"/>
                            <TextBlock Text="Загрузите преподавателей из Excel-файла (шаблон ниже)" 
                                       Foreground="Gray" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="📁 Выбрать файл" Click="ImportFromExcel" 
                                        Background="CadetBlue" Foreground="White" 
                                        Width="150" Height="35" Margin="0,0,10,0"/>
                                <Button Content="⬇️ Скачать шаблон" Click="DownloadTemplate" 
                                        Background="White" Foreground="CadetBlue" 
                                        BorderBrush="CadetBlue" BorderThickness="1" 
                                        Width="150" Height="35"/>
                            </StackPanel>
                            <TextBlock x:Name="importStatusTB" Foreground="#2E8B57" 
                                       TextWrapping="Wrap" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- 🔹 Блок: Экспорт в 1C XML -->
                    <Border BorderBrush="#4682B4" BorderThickness="1" CornerRadius="10" 
                            Background="#F0F8FF" Margin="0,0,0,20" Padding="15">
                        <StackPanel>
                            <TextBlock Text="🔄 Экспорт в 1C (XML)" FontWeight="Bold" FontSize="16" 
                                       Foreground="#4682B4" Margin="0,0,0,10"/>
                            <TextBlock Text="Совместимый формат для интеграции с 1C:Предприятие" 
                                       Foreground="Gray" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            <Button Content="📤 Экспортировать в XML" Click="ExportTo1C" 
                                    Background="#4682B4" Foreground="White" Height="35"/>
                        </StackPanel>
                    </Border>

                    <!-- 🔹 Блок: Импорт из 1C XML -->
                    <Border BorderBrush="#4682B4" BorderThickness="1" CornerRadius="10" 
                            Background="#F0F8FF" Margin="0,0,0,20" Padding="15">
                        <StackPanel>
                            <TextBlock Text="🔄 Импорт из 1C (XML)" FontWeight="Bold" FontSize="16" 
                                       Foreground="#4682B4" Margin="0,0,0,10"/>
                            <TextBlock Text="Загрузите данные из экспорта 1C" 
                                       Foreground="Gray" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            <Button Content="📥 Импортировать из XML" Click="ImportFrom1C" 
                                    Background="#4682B4" Foreground="White" Height="35"/>
                        </StackPanel>
                    </Border>

                    <!-- 🔹 Справка по формату -->
                    <Expander Header="ℹ️ Формат файла 1C (XML)" Margin="0,0,0,20" 
                              Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1">
                        <TextBox IsReadOnly="True" Height="120" TextWrapping="Wrap" 
                                 FontFamily="Consolas" FontSize="10" Background="White"
                                 Text="&lt;?xml version=&quot;1.0&quot; encoding=&quot;utf-8&quot;?&gt;&#10;&lt;Teachers&gt;&#10;  &lt;Teacher&gt;&#10;    &lt;FIO&gt;Иванов Иван Иванович&lt;/FIO&gt;&#10;    &lt;Login&gt;ivanov&lt;/Login&gt;&#10;    &lt;Email&gt;ivanov@school.ru&lt;/Email&gt;&#10;    &lt;Phone&gt;89001234567&lt;/Phone&gt;&#10;  &lt;/Teacher&gt;&#10;&lt;/Teachers&gt;"/>
                    </Expander>

                </StackPanel>
            </ScrollViewer>

            <!-- Кнопка выхода -->
            <Button Content="🔙 Вернуться к авторизации" HorizontalAlignment="Left" 
                    Click="OpenAuthorization" Foreground="White" VerticalAlignment="Bottom" 
                    Width="190" Height="30" Background="CadetBlue" BorderBrush="Black" 
                    BorderThickness="1" Margin="5"/>
        </Grid>
    </Grid>
</Page>