<UserControl x:Class="BPRapp.Pages.MainMenuAdmins.Admins_List.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="160" d:DesignWidth="900">

    <UserControl.Resources>
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" 
                          Color="#333333" Opacity="0.15" Direction="315"/>
    </UserControl.Resources>

    <Grid Margin="8">
        <Border Background="White" CornerRadius="12" Padding="15" 
                BorderBrush="#C5D5E5" BorderThickness="1" 
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Кнопки действий -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Button Content="✏️ Изменить" Click="EditAdmin" 
                            Width="100" Height="28" Margin="0,0,0,8" 
                            Background="#4CAF50" Foreground="White" Cursor="Hand" FontSize="12">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="🗑️ Удалить" Click="DeleteAdmin" 
                            Width="100" Height="28" 
                            Background="#F44336" Foreground="White" Cursor="Hand" FontSize="12">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Информация -->
                <Grid Grid.Column="1" Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,5">
                        <TextBlock Text="ФИО:" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>
                        <TextBox x:Name="FIOTB" IsEnabled="False" Height="26" 
                                 VerticalContentAlignment="Center" Padding="8,0" 
                                 Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,10,5">
                        <TextBlock Text="Логин:" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>
                        <TextBox x:Name="loginTB" IsEnabled="False" Height="26" 
                                 VerticalContentAlignment="Center" Padding="8,0" 
                                 Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>

                    <!-- 🔹 ДОБАВЛЕНО: Поле пароля -->
                    <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,5">
                        <TextBlock Text="Пароль:" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>
                        <TextBox x:Name="parolTB" IsEnabled="False" Height="26" 
                                 VerticalContentAlignment="Center" Padding="8,0" 
                                 Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,5,10,0">
                        <TextBlock Text="Email:" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>
                        <TextBox x:Name="emailTB" IsEnabled="False" Height="26" 
                                 VerticalContentAlignment="Center" Padding="8,0" 
                                 Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,5,0,0">
                        <TextBlock Text="Телефон:" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>
                        <TextBox x:Name="phone_numberTB" IsEnabled="False" Height="26" 
                                 VerticalContentAlignment="Center" Padding="8,0" 
                                 Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>