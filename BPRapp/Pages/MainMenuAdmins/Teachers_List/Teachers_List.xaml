<Page x:Class="BPRapp.Pages.MainMenuAdmins.Teachers_List.Teachers_List"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuAdmins.Teachers_List"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Teachers_List">

    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Преподаватели в системе" Foreground="White" 
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" 
                   FontSize="19" FontFamily="MV Boli"/>
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Grid Width="3" Margin="200,0,0,0" Background="CadetBlue" HorizontalAlignment="Left"/>
            <Grid Height="3" Margin="200,0,0,37" Background="CadetBlue" VerticalAlignment="Bottom"/>

            <!-- Меню -->
            <ScrollViewer Margin="0, 0, 0, 40" HorizontalAlignment="Left" Width="200" BorderBrush="White">
                <StackPanel Background="White">
                    <Button Content="🔐 Администраторы" HorizontalAlignment="Center" Click="OpenAdmins_List" 
                            Foreground="White" Width="170" Height="30" Background="CadetBlue" 
                            BorderBrush="Black" BorderThickness="1" Margin="5"/>
                    <Button Content="👨‍🏫 Преподаватели" HorizontalAlignment="Center" Click="OpenTeachers_List" 
                            Foreground="White" Width="170" Height="30" Background="#2E8B57" 
                            BorderBrush="Black" BorderThickness="1" Margin="5" FontWeight="Bold"/>
                    <Button Content="📤 Экспорт/Импорт" HorizontalAlignment="Center" Click="OpenExportImport" 
                            Foreground="White" Width="170" Height="30" Background="CadetBlue" 
                            BorderBrush="Black" BorderThickness="1" Margin="5"/>
                </StackPanel>
            </ScrollViewer>

            <!-- 🔹 ПАНЕЛЬ ПОИСКА -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,10,10,0">
                <TextBox x:Name="searchTB" Width="250" Height="30" 
                         VerticalContentAlignment="Center" Padding="10,0" FontSize="13"
                         TextChanged="SearchTB_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="White" BorderBrush="CadetBlue" 
                                                BorderThickness="1.5" CornerRadius="5">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <TextBlock Text="🔍 Поиск преподавателя..." 
                           VerticalAlignment="Center" Margin="10,0,0,0" 
                           Foreground="Gray" FontSize="13"/>
            </StackPanel>

            <!-- Список -->
            <ScrollViewer Margin="203, 50, 0, 40" BorderBrush="White">
                <StackPanel x:Name="Teachers_ListParent" Background="White"/>
            </ScrollViewer>

            <Button Content="➕ Добавить" HorizontalAlignment="Right" Click="AddTeacher" 
                    Foreground="White" VerticalAlignment="Bottom" Width="120" Height="30" 
                    Background="#2E8B57" BorderBrush="Black" BorderThickness="1" 
                    Margin="5" FontWeight="Bold"/>
            <Button Content="🔙 Вернуться к авторизации" HorizontalAlignment="Left" 
                    Click="OpenAuthorization" Foreground="White" VerticalAlignment="Bottom" 
                    Width="190" Height="30" Background="CadetBlue" BorderBrush="Black" 
                    BorderThickness="1" Margin="5"/>
        </Grid>
    </Grid>
</Page>
