<Page x:Class="BPRapp.Pages.MainMenuAdmins.Teachers_List.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="800"
      Title="Добавить преподавателя">
    <Page.Resources>
        <!-- 🎨 Корпоративные цвета -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>

        <!-- ✨ Тень для карточек -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" 
                         Color="#333333" Opacity="0.15" Direction="315"/>

        <!-- 🔘 Стиль кнопки -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                               CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 📝 Стиль TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C5D5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                               BorderBrush="{TemplateBinding BorderBrush}" 
                               BorderThickness="{TemplateBinding BorderThickness}" 
                               CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🏷️ Стиль заголовка поля -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Page.Resources>

    <!-- 🎨 Градиентный фон -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource LightBlue}" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 🔷 Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="White" CornerRadius="24" Width="48" Height="48" 
                       HorizontalAlignment="Left" Effect="{StaticResource CardShadow}">
                    <TextBlock Text="👨‍🏫" FontSize="26" 
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Добавить преподавателя" FontSize="20" FontWeight="Bold" 
                              Foreground="White"/>
                    <TextBlock Text="КГПАОУ Авиационный техникум имени А.Д. Швецова" 
                              FontSize="12" Foreground="#E6F2FF" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 📋 Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25">
            <Border Background="White" CornerRadius="12" Padding="25" 
                   Effect="{StaticResource CardShadow}" MaxWidth="600">
                <StackPanel>
                    <TextBlock Text="📌 Информация о преподавателе" 
                              Style="{StaticResource FieldLabel}" FontSize="15" 
                              Margin="0,0,0,20" Foreground="{StaticResource DarkBlueBrush}"/>

                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="ФИО *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FIOTB" Style="{StaticResource ModernTextBox}" 
                                ToolTip="Введите ФИО преподавателя"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="Логин *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="loginTB" Style="{StaticResource ModernTextBox}" 
                                ToolTip="Придумайте уникальный логин"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="Пароль *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="parolTB" Style="{StaticResource ModernTextBox}" 
                                ToolTip="Минимум 8 символов, буквы и цифры"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="Электронная почта" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="emailTB" Style="{StaticResource ModernTextBox}" 
                                ToolTip="example@domain.com"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Номер телефона" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="phone_numberTB" Style="{StaticResource ModernTextBox}" 
                                ToolTip="+7 (999) 123-45-67"/>
                    </StackPanel>

                    <!-- 💡 Подсказка -->
                    <Border Background="#FFF9E6" CornerRadius="8" Padding="12" 
                           BorderBrush="#FFD700" BorderThickness="1" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💡" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Поля с * обязательны для заполнения" 
                                      FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- 🔷 Кнопки -->
        <Border Grid.Row="2" Background="White" Padding="25,20" 
               BorderBrush="{StaticResource LightBlueBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Content="← Назад" Click="GoBack" Width="130" Height="35" 
                       Background="#6C757D" Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BthAdd" Click="AddTeacher" Content="💾 Сохранить" 
                       Style="{StaticResource ModernButton}" Width="180" 
                       Grid.Column="2" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Page>