<Page x:Class="BPRapp.Pages.MainMenuAdmins.Teachers_List.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuAdmins.Teachers_List"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Добавить нового преподавателя" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" Margin="0,0,0,0" FontSize="19" FontFamily="MV Boli" Grid.Column="1" />
        </Grid>

        <Grid Margin="0,45,0,0" Background="White">
            <Button Content="Назад" HorizontalAlignment="Left" Click="GoBack" Foreground="White"  VerticalAlignment="Top" Width="60" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="10,10,0,0"/>
            <Label Content="Введите ФИО:" Margin="0,0,310,300" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="FIOTB" HorizontalAlignment="Center" Margin="0,0,0,250" Width="400" Height="30" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Label Content="Укажите логин:" Margin="0,0,303,200" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="loginTB" HorizontalAlignment="Center" Margin="0,0,0,150" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Label Content="Укажите пароль:" Margin="0,0,295,100" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="parolTB" HorizontalAlignment="Center" Margin="0,0,0,50" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Label Content="Укажите электронную почту:" Margin="0,0,230,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="emailTB" HorizontalAlignment="Center" Margin="0,50,0,0" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Label Content="Укажите номер телефона:" Margin="0,100,245,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="phone_numberTB" HorizontalAlignment="Center" Margin="0,150,0,0" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Button x:Name="BthAdd" Click="AddTeacher" Content="Добавить нового преподавателя" HorizontalAlignment="Center" Margin="0,330,0,0" Foreground="White" VerticalAlignment="Center" Width="200" Height="31" Background="CadetBlue" BorderBrush="Black" BorderThickness="1"/>
        </Grid>
    </Grid>
</Page>