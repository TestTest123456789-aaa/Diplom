<Page x:Class="BPRapp.Pages.NotificationSettings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="600"
      Title="Настройки уведомлений">

    <Page.Resources>
        <!-- 🎨 Корпоративные цвета -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>
        <Color x:Key="AccentBlue">#4A86C7</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>

        <!-- ✨ Тень для карточек -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="30" ShadowDepth="10" 
                          Color="#333333" Opacity="0.3" Direction="315"/>

        <!-- 🔘 Стиль кнопки -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🔘 Стиль ToggleButton для переключателя -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" Background="#E0E0E0" CornerRadius="15" Width="60" Height="30"/>
                            <Ellipse x:Name="Thumb" Fill="White" Width="24" Height="24" 
                                     HorizontalAlignment="Left" Margin="3"
                                     Effect="{StaticResource CardShadow}">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Track" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#4CAF50" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="30" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Track"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#E0E0E0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!-- 🎨 Градиентный фон -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2E8B57" Offset="0.0"/>
                <GradientStop Color="#20B2AA" Offset="0.5"/>
                <GradientStop Color="#4682B4" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Декоративные элементы -->
        <Canvas>
            <Ellipse Width="300" Height="300" Fill="White" Opacity="0.1" 
                     Canvas.Left="50" Canvas.Top="100"/>
            <Ellipse Width="200" Height="200" Fill="White" Opacity="0.1" 
                     Canvas.Right="100" Canvas.Bottom="150"/>
        </Canvas>

        <!-- 🔷 Карточка настроек -->
        <Border Background="White" CornerRadius="20" Width="500" Height="520"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Effect="{StaticResource CardShadow}">
            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25">
                    <Border Background="{StaticResource PrimaryBlueBrush}" 
                            Width="70" Height="70" CornerRadius="35" 
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="🔔" FontSize="32" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Настройки уведомлений" FontSize="22" FontWeight="Bold" 
                               Foreground="{StaticResource DarkBlueBrush}" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Управление email-оповещениями" FontSize="13" 
                               Foreground="Gray" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Контент -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <!-- Блок: Включение уведомлений -->
                    <Border Background="#F8F9FA" CornerRadius="12" Padding="20" Margin="0,0,0,15"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="📧 Email-уведомления" 
                                           FontWeight="Bold" FontSize="15" 
                                           Foreground="{StaticResource DarkBlueBrush}"/>
                                <TextBlock Text=" (ВПР)" 
                                           FontWeight="Normal" FontSize="13" 
                                           Foreground="Gray"/>
                            </StackPanel>
                            <TextBlock Text="Получать напоминания о ВПР за день до проведения" 
                                       FontSize="13" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="NotificationStatusText" 
                                           Text="Уведомления включены" 
                                           VerticalAlignment="Center" 
                                           FontSize="13"
                                           Foreground="{StaticResource DarkBlueBrush}"/>
                                <ToggleButton x:Name="NotificationToggle" 
                                              Grid.Column="1" 
                                              Style="{StaticResource ToggleSwitch}"
                                              IsChecked="True"
                                              Click="NotificationToggle_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Блок: Информация -->
                    <Border Background="#FFF3CD" CornerRadius="12" Padding="15"
                            BorderBrush="#FFD700" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ️" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Как работают уведомления?" 
                                           FontWeight="SemiBold" FontSize="13" 
                                           Foreground="#856404" Margin="0,0,0,5"/>
                                <TextBlock Text="• Проверка запускается ежедневно в 9:00" 
                                           FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                <TextBlock Text="• Письмо отправляется за 24 часа до ВПР" 
                                           FontSize="11" Foreground="#666"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Center" Orientation="Horizontal">
                    <Button Content="Отмена" Click="CancelSettings" 
                            Width="120" Height="40" Margin="0,0,15,0"
                            Background="#6C757D" Foreground="White" FontSize="13" FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        CornerRadius="10" Padding="20,10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#545B62"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="💾 Сохранить" Click="SaveSettings" 
                            Width="150" Height="40"
                            Style="{StaticResource ModernButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>