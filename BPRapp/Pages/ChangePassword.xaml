<Page x:Class="BPRapp.Pages.ChangePassword"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Новый пароль">
    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="ВПР" Foreground="White" HorizontalContentAlignment="Center" 
               VerticalContentAlignment="Bottom" FontSize="19" FontFamily="MV Boli"/>
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Label Content="Смена пароля" HorizontalContentAlignment="Center" 
               FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" 
               VerticalAlignment="Top" Width="340" Foreground="CadetBlue"/>

            <Button Content="Назад" HorizontalAlignment="Left" Click="GoBack" 
                Foreground="White" VerticalAlignment="Top" Width="60" Height="30" 
                Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="10,10,0,0"/>

            <StackPanel Margin="0,100,0,0" HorizontalAlignment="Center" Width="400">
                <TextBlock Text="Требования к паролю:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="• Минимум 8 символов" Margin="5,0,0,0"/>
                <TextBlock Text="• Должен содержать буквы и цифры" Margin="5,0,0,0"/>

                <Label Content="Новый пароль:" Margin="0,20,0,0"/>
                <PasswordBox x:Name="newPasswordTB" Height="32" Background="White" 
                         BorderBrush="Black" BorderThickness="1"/>

                <Label Content="Подтвердите пароль:" Margin="0,10,0,0"/>
                <PasswordBox x:Name="confirmPasswordTB" Height="32" Background="White" 
                         BorderBrush="Black" BorderThickness="1"/>

                <Button Content="Сохранить новый пароль" Click="SavePassword" 
                    Foreground="White" VerticalAlignment="Top" Width="200" Height="30" 
                    Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="0,20,0,0"/>
            </StackPanel>

            <TextBlock x:Name="statusText" HorizontalAlignment="Center" Margin="0,380,0,0" 
                   TextWrapping="Wrap" TextAlignment="Center" Foreground="Red" 
                   VerticalAlignment="Top" Width="400"/>
        </Grid>
    </Grid>
</Page>
