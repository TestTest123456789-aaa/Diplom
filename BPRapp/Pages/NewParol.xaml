<Page x:Class="BPRapp.Pages.NewParol"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Новый пароль">
    <Page.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Color="#333333" Opacity="0.15" Direction="315"/>
    </Page.Resources>
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4B79A1" Offset="0"/>
                <GradientStop Color="#283E51" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Border Background="White" Width="450" Height="520" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center" Effect="{StaticResource CardShadow}">
            <Grid Margin="30">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🔐 Придумайте новый пароль" FontSize="24" FontWeight="Bold" Foreground="#2E5C8A" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="Требования:" FontWeight="SemiBold" Margin="0,0,0,10" FontSize="13" Foreground="#333"/>
                    <TextBlock Text="• Минимум 8 символов" Margin="10,0,0,3" FontSize="12" Foreground="#666"/>
                    <TextBlock Text="• Должен содержать буквы и цифры" Margin="10,0,0,20" FontSize="12" Foreground="#666"/>

                    <TextBlock Text="Новый пароль:" FontSize="13" FontWeight="SemiBold" Margin="0,5,0,5"/>
                    <TextBox x:Name="parolTB" Height="38" Padding="8" FontSize="14" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,15"/>

                    <TextBlock Text="Подтвердите пароль:" FontSize="13" FontWeight="SemiBold" Margin="0,5,0,5"/>
                    <TextBox x:Name="confirm_parolTB" Height="38" Padding="8" FontSize="14" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,25"/>

                    <Button Content="💾 Создать новый пароль" Click="CreateParol" Width="220" Height="42" Background="#5B9BD5" Foreground="White" FontWeight="SemiBold" FontSize="14" Cursor="Hand" Margin="0,0,0,10"/>
                    <Button Content="← Назад" Click="GoBack" Width="120" Height="36" Background="Transparent" Foreground="#6C757D" Cursor="Hand" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>