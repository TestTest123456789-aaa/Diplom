<Page x:Class="BPRapp.Pages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Authorization">

    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="ВПР" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" Margin="0,0,0,0" FontSize="19" FontFamily="MV Boli" Grid.Column="1" />
        </Grid>

        <Grid Margin="0,45,0,0" Background="White">
            <Label Content="Авторизация" HorizontalContentAlignment="Center" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top" Width="340" Margin="0,0,0,0" Foreground="CadetBlue"/>
            <Label Content="Логин:" Margin="0,0,350,280" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="loginTB" HorizontalAlignment="Center" Margin="0,0,0,220" Width="400" Height="30" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Label Content="Пароль:" Margin="0,0,350,160" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="parolTB" HorizontalAlignment="Center" Margin="0,0,0,100" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Button Content="Войти" HorizontalAlignment="Center" Click ="Authorize" Foreground="White"  VerticalAlignment="Center" Width="200" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="0,10,0,0"/>
            <Label Content="Забыли пароль от аккаунта? - " Margin="0,130,100,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <Button Click="GetBackParol"  Content="Восстановить пароль" HorizontalAlignment="Center" Margin="185,130,0,0" Foreground="CadetBlue" VerticalAlignment="Center" Width="121" Height="31" Background="White" BorderBrush="White" BorderThickness="1"/>
            <Label Content="Если у вас ещё нет аккаунта - зарегистрируйтесь" Margin="0,240,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <Button Click="OpenRegistration"  Content="Зарегистрироваться" HorizontalAlignment="Center" Margin="0,300,0,0" Foreground="White" VerticalAlignment="Center" Width="200" Height="31" Background="CadetBlue" BorderBrush="Black" BorderThickness="1"/>
        </Grid>
    </Grid>
</Page>
