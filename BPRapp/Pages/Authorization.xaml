<Page x:Class="BPRapp.Pages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Авторизация - Система ВПР" 
      MinHeight="600" MinWidth="900">

    <Page.Resources>
        <!-- 🎨 Корпоративные цвета -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>
        <Color x:Key="AccentBlue">#4A86C7</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>

        <!-- ✨ Тень -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="30" ShadowDepth="10" 
                          Color="#333333" Opacity="0.3" Direction="315"/>

        <!-- 🔘 Стиль кнопки -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 📝 Стиль TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!-- 🎨 Градиентный фон -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2E8B57" Offset="0.0"/>
                <GradientStop Color="#20B2AA" Offset="0.5"/>
                <GradientStop Color="#4682B4" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Декоративные элементы -->
        <Canvas>
            <Ellipse Width="300" Height="300" Fill="White" Opacity="0.1" 
                     Canvas.Left="50" Canvas.Top="100"/>
            <Ellipse Width="200" Height="200" Fill="White" Opacity="0.1" 
                     Canvas.Right="100" Canvas.Bottom="150"/>
        </Canvas>

        <!-- 🔷 Форма авторизации -->
        <Border Background="White" CornerRadius="20" Width="450" Height="590"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Effect="{StaticResource CardShadow}">
            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Логотип и заголовок -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Border Background="{StaticResource PrimaryBlueBrush}" 
                            Width="80" Height="80" CornerRadius="40" 
                            HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="📋" FontSize="40" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Система ВПР" FontSize="28" FontWeight="Bold" 
                               Foreground="{StaticResource DarkBlueBrush}" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Авторизация" FontSize="16" Foreground="Gray" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Поля ввода -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <!-- Логин -->
                    <TextBlock Text="Логин" FontWeight="Bold" Foreground="#333" 
                               Margin="0,0,0,8" FontSize="13"/>
                    <Border BorderBrush="#DDD" BorderThickness="1.5" CornerRadius="8" 
                            Background="#FAFAFA">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="👤" FontSize="18" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="loginTB" Grid.Column="1" 
                                     BorderThickness="0" Background="Transparent"
                                     Style="{StaticResource ModernTextBox}" Text="login123"/>
                        </Grid>
                    </Border>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" FontWeight="Bold" Foreground="#333" 
                               Margin="0,20,0,8" FontSize="13"/>
                    <Border BorderBrush="#DDD" BorderThickness="1.5" CornerRadius="8" 
                            Background="#FAFAFA">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔒" FontSize="18" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="parolTB" Grid.Column="1" 
                                         BorderThickness="0" Background="Transparent"
                                         Padding="10,0" FontSize="14" 
                                         VerticalContentAlignment="Center" Height="45" Text="parol123"/>
                        </Grid>
                    </Border>

                    <!-- Кнопка входа -->
                    <Button Content="Войти в систему" Click="Authorize" 
                            Height="50" Margin="0,30,0,0"
                            Style="{StaticResource ModernButton}"/>
                </StackPanel>

                <!-- Подвал -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                    <TextBlock Text="© 2026 Система управления ВПР" 
                               Foreground="#999" FontSize="11" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="КГПАОУ Авиационный техникум имени А.Д. Швецова" 
                               Foreground="#999" FontSize="10" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>