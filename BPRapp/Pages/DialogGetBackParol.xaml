<Page x:Class="BPRapp.Pages.DialogGetBackParol"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Восстановление пароля">
    <Page.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Color="#333333" Opacity="0.15" Direction="315"/>
    </Page.Resources>
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4B79A1" Offset="0"/>
                <GradientStop Color="#283E51" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Border Background="White" Width="450" Height="400" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center" Effect="{StaticResource CardShadow}">
            <Grid Margin="30">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="✉️ Восстановление пароля" FontSize="24" FontWeight="Bold" Foreground="#2E5C8A" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="На вашу почту отправлен 6-значный код подтверждения." TextWrapping="Wrap" HorizontalAlignment="Center" FontSize="14" Foreground="#555" Margin="0,0,0,20"/>

                    <TextBlock Text="Введите полученный код:" FontSize="13" FontWeight="SemiBold" Margin="0,5,0,5"/>
                    <TextBox x:Name="kod_vosstanovleniaTB" Height="48" Padding="8" FontSize="18" TextAlignment="Center" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,25" MaxLength="6"/>

                    <Button Content="✅ Подтвердить код" Click="SendKode" Width="200" Height="42" Background="#5B9BD5" Foreground="White" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,15"/>
                    <Button Content="← Назад" Click="GoBack" Width="120" Height="36" Background="Transparent" Foreground="#6C757D" Cursor="Hand" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>