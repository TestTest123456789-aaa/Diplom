<Page x:Class="BPRapp.Pages.EnterRecoveryCode"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Подтверждение кода">
    <Page.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Color="#333333" Opacity="0.15" Direction="315"/>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4B79A1" Offset="0"/>
                <GradientStop Color="#283E51" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Border Background="White" Width="450" Height="450" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center" Effect="{StaticResource CardShadow}">
            <Grid Margin="30">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🛡️ Подтверждение кода" FontSize="24" FontWeight="Bold" Foreground="#2E5C8A" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="Введите 6-значный код из письма:" TextWrapping="Wrap" HorizontalAlignment="Center" FontSize="14" Foreground="#555" Margin="0,0,0,15"/>

                    <TextBox x:Name="codeTB" Height="48" Padding="8" FontSize="18" TextAlignment="Center" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,20" MaxLength="6" PreviewTextInput="CodeTB_PreviewTextInput"/>

                    <TextBlock x:Name="statusText" TextWrapping="Wrap" TextAlignment="Center" Foreground="Red" FontSize="12" Height="30" Margin="0,0,0,10"/>

                    <Button Content="🔍 Подтвердить" Click="VerifyCode" Width="200" Height="42" Background="#5B9BD5" Foreground="White" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,10"/>
                    <Button Content="📤 Отправить код повторно" Click="ResendCode" Width="220" Height="36" Background="Transparent" Foreground="#5B9BD5" Cursor="Hand" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>