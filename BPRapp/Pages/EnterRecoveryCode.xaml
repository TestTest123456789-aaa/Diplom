<Page x:Class="BPRapp.Pages.EnterRecoveryCode"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Введите код">
    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="ВПР" Foreground="White" HorizontalContentAlignment="Center" 
               VerticalContentAlignment="Bottom" FontSize="19" FontFamily="MV Boli"/>
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Label Content="Подтверждение кода" HorizontalContentAlignment="Center" 
               FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" 
               VerticalAlignment="Top" Width="340" Foreground="CadetBlue"/>

            <Button Content="Назад" HorizontalAlignment="Left" Click="GoBack" 
                Foreground="White" VerticalAlignment="Top" Width="60" Height="30" 
                Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="10,10,0,0"/>

            <Label Content="Введите 6-значный код из письма:" 
               Margin="0,100,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Height="26"/>

            <TextBox x:Name="codeTB" HorizontalAlignment="Center" Margin="0,130,0,0" 
                 Width="200" Height="32" Background="White" BorderBrush="Black" 
                 BorderThickness="1" VerticalAlignment="Top" TextAlignment="Center" 
                 MaxLength="6" PreviewTextInput="CodeTB_PreviewTextInput"/>

            <Button Content="Подтвердить" HorizontalAlignment="Center" Click="VerifyCode" 
                Foreground="White" VerticalAlignment="Top" Width="200" Height="30" 
                Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="0,180,0,0"/>

            <TextBlock x:Name="statusText" HorizontalAlignment="Center" Margin="0,220,0,0" 
                   TextWrapping="Wrap" TextAlignment="Center" Foreground="Red" 
                   VerticalAlignment="Top" Width="400"/>

            <Button Content="Отправить код повторно" HorizontalAlignment="Center" Click="ResendCode" 
                Foreground="CadetBlue" VerticalAlignment="Top" Width="200" Height="25" 
                Background="White" BorderBrush="White" BorderThickness="1" Margin="0,260,0,0"/>
        </Grid>
    </Grid>
</Page>