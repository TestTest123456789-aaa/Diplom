<Page x:Class="BPRapp.Pages.Registration"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Registration">

    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="ВПР" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" Margin="0,0,0,0" FontSize="19" FontFamily="MV Boli" Grid.Column="1" />
        </Grid>

        <Grid Margin="0,45,0,0" Background="White">
            <Label Content="Регистрация" HorizontalContentAlignment="Center" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top" Width="340" Margin="0,0,0,0" Foreground="CadetBlue"/>
            <Button Content="Назад" HorizontalAlignment="Left" Click ="GoBack" Foreground="White"  VerticalAlignment="Top" Width="60" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="10,10,0,0"/>
            <Label Content="Введите ваше ФИО:" Margin="0,0,280,300" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="FIOTB" HorizontalAlignment="Center" Margin="0,0,0,250" Width="400" Height="30" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Label Content="Придумайте логин:" Margin="0,0,283,200" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="loginTB" HorizontalAlignment="Center" Margin="0,0,0,150" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Label Content="Придумайте пароль:" Margin="0,0,275,100" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="parolTB" HorizontalAlignment="Center" Margin="0,0,0,50" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Label Content="Подтвердите пароль:" Margin="0,0,272,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="confirm_parolTB" HorizontalAlignment="Center" Margin="0,50,0,0" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Label Content="Введите адрес электронной почты:" Margin="0,95,195,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="emailTB" HorizontalAlignment="Center" Margin="0,150,0,0" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Label Content="Введите номер телефона(не обязательно):" Margin="0,195,155,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="phoneTB" HorizontalAlignment="Center" Margin="0,245,0,0" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Button Click="Regin" Content="Зарегистрироваться" HorizontalAlignment="Center" Margin="0,330,0,0" Foreground="White" VerticalAlignment="Center" Width="200" Height="31" Background="CadetBlue" BorderBrush="Black" BorderThickness="1"/>
        </Grid>
    </Grid>
</Page>
