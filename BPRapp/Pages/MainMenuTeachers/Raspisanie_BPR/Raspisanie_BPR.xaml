<Page x:Class="BPRapp.Pages.MainMenuTeachers.Raspisanie_BPR.Raspisanie_BPR"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:BPRapp.Pages.MainMenuTeachers.Raspisanie_BPR"
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Raspisanie_BPR"
      mc:Ignorable="d"
      d:DesignHeight="750" d:DesignWidth="1200"
      Title="Расписание ВПР">

    <Page.Resources>
        <!-- 🎨 Корпоративные цвета -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>
        <Color x:Key="AccentBlue">#4A86C7</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>

        <!-- ✨ Тень для карточек -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" 
                          Color="#333333" Opacity="0.15" Direction="315"/>

        <!-- 🔘 Стили кнопок -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="{StaticResource LightBlueBrush}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource LightBlueBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🔽 Стиль ComboBox (добавлен) -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C5D5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ContentPresenter Content="{TemplateBinding Text}" Margin="6,0" VerticalAlignment="Center"/>
                            </Border>
                            <ToggleButton Grid.Column="1" Focusable="false"
                                        IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                        ClickMode="Press" HorizontalAlignment="Right" Width="24"
                                        Background="Transparent" BorderThickness="0">
                                <Path Data="M0,0 L4,4 L8,0 Z" Fill="{StaticResource DarkBlueBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Width="6" Height="4"/>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="{StaticResource PrimaryBlueBrush}"
                                        BorderThickness="1" CornerRadius="5" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Конвертеры -->
        <converters:DayToBackgroundConverter x:Key="DayToBackgroundConverter"/>
        <converters:BoolToVisConverter x:Key="BoolToVisConverter"/>
        <converters:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
        <converters:LessonNameConverter x:Key="LessonNameConverter"/>
        <converters:TeacherNameConverter x:Key="TeacherNameConverter"/>
        <converters:GroupNameConverter x:Key="GroupNameConverter"/>
    </Page.Resources>

    <!-- 🎨 Градиентный фон -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource LightBlue}" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔷 Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="White" CornerRadius="24" Width="48" Height="48" 
                        HorizontalAlignment="Left" Effect="{StaticResource CardShadow}">
                    <TextBlock Text="📅" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Расписание ВПР" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="КГПАОУ Авиационный техникум имени А.Д. Швецова"
                               FontSize="12" Foreground="#E6F2FF" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Информация о пользователе -->
                <StackPanel x:Name="UserInfoPanel" Grid.Column="1" 
                            Margin="0,0,20,0" VerticalAlignment="Center" 
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="FioLbl" Text="" FontWeight="Bold" 
                               Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="ContactLbl" Text="" 
                               Foreground="#E6F2FF" FontSize="11" FontStyle="Italic"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 📋 Основное содержимое -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: Меню -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" 
                    Padding="15" Effect="{StaticResource CardShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="📌 Разделы" FontSize="16" FontWeight="Bold" 
                                   Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,15"/>

                        <Button Content="📋 Списки ВПР" Click="OpenSpiski_BPR" Style="{StaticResource MenuButton}"/>
                        <Button Content="📅 Расписание ВПР" Click="OpenRaspisanie_BPR" Style="{StaticResource MenuButton}"
                                Background="{StaticResource LightBlueBrush}" BorderBrush="{StaticResource PrimaryBlueBrush}"/>
                        <Button Content="🔒 Ближайшие ВПР" Click="OpenClosed_BRP" Style="{StaticResource MenuButton}"/>
                        <Button Content="📤 Экспорт/Импорт" Click="OpenExport" Style="{StaticResource MenuButton}"/>

                        <Separator Margin="5,10" Background="{StaticResource LightBlueBrush}"/>

                        <!-- 🔹 Справочники -->
                        <TextBlock Text="📚 Справочники" FontSize="16" FontWeight="Bold" 
           Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,15"/>

                        <Button Content="📚 Учебные предметы" Click="OpenLessons" Style="{StaticResource MenuButton}"/>
                        <Button Content="🚪 Кабинеты" Click="OpenKabinets" Style="{StaticResource MenuButton}"/>
                        <Button Content="👥 Группы" Click="OpenGroups" Style="{StaticResource MenuButton}"/>
                        <Button Content="🏢 Отделения" Click="OpenDepartments" Style="{StaticResource MenuButton}"/>

                        <Separator Margin="5,10" Background="{StaticResource LightBlueBrush}"/>

                        <!-- 🔹 Кнопка ВЫХОД -->
                        <Button Content="🚪 Выйти из системы" Click="OpenAuthorization" Width="190" Height="45" Margin="5,5,5,15">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MenuButton}">
                                    <Setter Property="Background" Value="#FFE5E5"/>
                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFCDD2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Правая панель: Календарь -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" 
                    Padding="20" Margin="20,0,0,0" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Выбор месяца/года -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <ComboBox x:Name="MonthCB" Width="140" SelectionChanged="UpdateCalendar" 
                                  Margin="0,0,10,0" Style="{StaticResource ModernComboBox}"/>
                        <ComboBox x:Name="YearCB" Width="100" SelectionChanged="UpdateCalendar" 
                                  Style="{StaticResource ModernComboBox}"/>
                    </StackPanel>

                    <!-- Календарь -->
                    <Grid x:Name="CalendarGrid" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Дни недели -->
                        <Border Grid.Row="0" Background="{StaticResource LightBlueBrush}" CornerRadius="8,8,0,0">
                            <Grid x:Name="WeekHeader">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Пн" HorizontalAlignment="Center" FontWeight="Bold" 
                                           Foreground="{StaticResource DarkBlueBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Вт" Grid.Column="1" HorizontalAlignment="Center" FontWeight="Bold" 
                                           Foreground="{StaticResource DarkBlueBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Ср" Grid.Column="2" HorizontalAlignment="Center" FontWeight="Bold" 
                                           Foreground="{StaticResource DarkBlueBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Чт" Grid.Column="3" HorizontalAlignment="Center" FontWeight="Bold" 
                                           Foreground="{StaticResource DarkBlueBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Пт" Grid.Column="4" HorizontalAlignment="Center" FontWeight="Bold" 
                                           Foreground="{StaticResource DarkBlueBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Сб" Grid.Column="5" HorizontalAlignment="Center" FontWeight="Bold" 
                                           Foreground="{StaticResource DarkBlueBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Вс" Grid.Column="6" HorizontalAlignment="Center" FontWeight="Bold" 
                                           Foreground="{StaticResource DarkBlueBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Дни месяца -->
                        <ItemsControl x:Name="DaysIC" Grid.Row="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7" Rows="6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0" BorderThickness="0.5" Padding="5"
                                            Cursor="Hand" MinHeight="70">
                                        <Border.ToolTip>
                                            <ToolTip Placement="Right" MaxWidth="400">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Day, StringFormat='📅 {0} число'}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Margin="0,0,0,10" Foreground="{StaticResource DarkBlueBrush}"/>
                                                    <ItemsControl ItemsSource="{Binding BPRList}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#F8FBFF" Padding="10"
                                                                        Margin="0,4" CornerRadius="6"
                                                                        BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="1">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Time, StringFormat='⏰ {0}'}"
                                                                                   FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}"/>
                                                                        <TextBlock Margin="0,3,0,0">
                                                                            <Run Text="📚 "/>
                                                                            <Run Text="{Binding Path=., Converter={StaticResource LessonNameConverter}}"/>
                                                                        </TextBlock>
                                                                        <TextBlock Margin="0,2,0,0">
                                                                            <Run Text="👨‍🏫 "/>
                                                                            <Run Text="{Binding Path=., Converter={StaticResource TeacherNameConverter}}"/>
                                                                        </TextBlock>
                                                                        <TextBlock Text="{Binding Room, StringFormat='🚪 Кабинет: {0}'}"
                                                                                   FontStyle="Italic" Margin="0,2,0,0"/>
                                                                        <TextBlock Margin="0,2,0,0">
                                                                            <Run Text="👥 "/>
                                                                            <Run Text="{Binding Path=., Converter={StaticResource GroupNameConverter}}"/>
                                                                        </TextBlock>
                                                                        <TextBlock Text="{Binding Count_Students, StringFormat='📝 Студентов: {0}'}"
                                                                                   FontWeight="SemiBold" Foreground="{StaticResource PrimaryBlueBrush}" Margin="0,3,0,0"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <Grid>
                                            <TextBlock Text="{Binding Day}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Top"
                                                       FontWeight="{Binding HasEvent, Converter={StaticResource BoolToFontWeightConverter}}"
                                                       FontSize="14"
                                                       Foreground="{StaticResource DarkBlueBrush}"/>
                                            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                    Background="{StaticResource PrimaryBlueBrush}" CornerRadius="10"
                                                    Padding="5,2" Margin="3"
                                                    Visibility="{Binding HasEvent, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock Text="{Binding BPRList.Count}"
                                                           Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource DayToBackgroundConverter}">
                                                <Binding Path="Day"/>
                                                <Binding Path="HasEvent"/>
                                            </MultiBinding>
                                        </Border.Background>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>