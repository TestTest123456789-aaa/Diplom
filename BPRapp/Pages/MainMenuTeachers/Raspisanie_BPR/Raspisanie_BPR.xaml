<Page x:Class="BPRapp.Pages.MainMenuTeachers.Raspisanie_BPR.Raspisanie_BPR"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:BPRapp.Pages.MainMenuTeachers.Raspisanie_BPR"
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Raspisanie_BPR"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Raspisanie_BPR">
    <Page.Resources>
        <converters:DayToBackgroundConverter x:Key="DayToBackgroundConverter"/>
        <converters:BoolToVisConverter x:Key="BoolToVisConverter"/>
        <converters:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
        <converters:LessonNameConverter x:Key="LessonNameConverter"/>
        <converters:TeacherNameConverter x:Key="TeacherNameConverter"/>
        <converters:GroupNameConverter x:Key="GroupNameConverter"/>
    </Page.Resources>

    <Grid>
        <StackPanel x:Name="UserInfoPanel" Margin="10,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Panel.ZIndex="100">
            <TextBlock x:Name="FioLbl" Text="" FontWeight="Bold" Foreground="White" FontSize="14"/>
            <TextBlock x:Name="ContactLbl" Text="" Foreground="#C8D8E4" FontSize="11" Margin="0,0,0,0" FontStyle="Italic"/>
        </StackPanel>

        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Расписание ВПР" Foreground="White" 
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" 
                   FontSize="19" FontFamily="MV Boli"/>
        </Grid>

        <Grid Margin="0,45,0,0" Background="White">
            <Grid Width="3" Margin="200,0,0,0" Background="CadetBlue" HorizontalAlignment="Left"/>
            <ScrollViewer Margin="0, 0, 0, 40" HorizontalAlignment="Left" Width="200" BorderBrush="White">
                <StackPanel Background="White">
                    <Button Content="📋 Списки ВПР" Click="OpenSpiski_BPR" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="📅 Расписание ВПР" Click="OpenRaspisanie_BPR" 
Foreground="White" Width="170" Height="30" 
Background="#2E8B57" Margin="5" FontWeight="Bold"/>
                    <Button Content="🔒 Ближайшие ВПР" Click="OpenClosed_BRP" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="📤 Экспорт/Импорт" Click="OpenExport" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="📚 Учебные предметы" Click="OpenLessons" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="🚪 Кабинеты" Click="OpenKabinets" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="👥 Группы" Click="OpenGroups" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="🏢 Отделения" Click="OpenDepartments" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Margin="203, 0, 0, 0" Background="White">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                            VerticalAlignment="Top" Margin="10,10">
                    <ComboBox x:Name="MonthCB" Width="120" SelectionChanged="UpdateCalendar" Margin="0,0,5,0"/>
                    <ComboBox x:Name="YearCB" Width="80" SelectionChanged="UpdateCalendar"/>
                </StackPanel>

                <Grid x:Name="CalendarGrid" Margin="20,40,20,0" Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="WeekHeader" Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Пн" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="Вт" Grid.Column="1" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="Ср" Grid.Column="2" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="Чт" Grid.Column="3" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="Пт" Grid.Column="4" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="Сб" Grid.Column="5" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="Вс" Grid.Column="6" HorizontalAlignment="Center" FontWeight="Bold"/>
                    </Grid>

                    <ItemsControl x:Name="DaysIC" Grid.Row="1">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" Rows="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CCC" BorderThickness="0.5" Padding="3" 
                                        Cursor="Hand" MinHeight="60">
                                    <Border.ToolTip>
                                        <ToolTip Placement="Right" MaxWidth="350">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Day, StringFormat='📅 {0} число'}" 
                                                           FontWeight="Bold" FontSize="14" 
                                                           Margin="0,0,0,8" Foreground="CadetBlue"/>
                                                <ItemsControl ItemsSource="{Binding BPRList}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#F8FBFF" Padding="8" 
                                                                    Margin="0,3" CornerRadius="5" 
                                                                    BorderBrush="CadetBlue" BorderThickness="1">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Time, StringFormat='⏰ {0}'}" 
                                                                               FontWeight="Bold" Foreground="#2E8B57"/>
                                                                    <TextBlock Margin="0,2,0,0">
                                                                        <Run Text="📚 "/>
                                                                        <Run Text="{Binding Path=., Converter={StaticResource LessonNameConverter}}"/>
                                                                    </TextBlock>
                                                                    <TextBlock Margin="0,2,0,0">
                                                                        <Run Text="👨‍🏫 "/>
                                                                        <Run Text="{Binding Path=., Converter={StaticResource TeacherNameConverter}}"/>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding Room, StringFormat='🚪 Кабинет: {0}'}" 
                                                                               FontStyle="Italic" Margin="0,2,0,0"/>
                                                                    <TextBlock Margin="0,2,0,0">
                                                                        <Run Text="👥 "/>
                                                                        <Run Text="{Binding Path=., Converter={StaticResource GroupNameConverter}}"/>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding Count_Students, StringFormat='📝 Студентов: {0}'}" 
                                                                               FontWeight="Bold" Foreground="#4169E1" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>

                                    <Grid>
                                        <TextBlock Text="{Binding Day}" 
                                                   HorizontalAlignment="Right" 
                                                   VerticalAlignment="Top" 
                                                   FontWeight="{Binding HasEvent, Converter={StaticResource BoolToFontWeightConverter}}"
                                                   FontSize="14"/>
                                        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                Background="CadetBlue" CornerRadius="10" 
                                                Padding="4,2" Margin="2"
                                                Visibility="{Binding HasEvent, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock Text="{Binding BPRList.Count}" 
                                                       Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>

                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource DayToBackgroundConverter}">
                                            <Binding Path="Day"/>
                                            <Binding Path="HasEvent"/>
                                        </MultiBinding>
                                    </Border.Background>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>

            <Button Content="Вернуться к авторизации" HorizontalAlignment="Left" 
                    Click="OpenAuthorization" Foreground="White" VerticalAlignment="Bottom" 
                    Width="190" Height="30" Background="CadetBlue" Margin="5"/>
        </Grid>
    </Grid>
</Page>