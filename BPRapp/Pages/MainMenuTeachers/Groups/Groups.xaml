<Page x:Class="BPRapp.Pages.MainMenuTeachers.Groups.Groups"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Groups"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Groups">

    <Grid>
        <StackPanel x:Name="UserInfoPanel" Margin="10,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Panel.ZIndex="100">
            <TextBlock x:Name="FioLbl" Text="" FontWeight="Bold" Foreground="White" FontSize="14"/>
            <TextBlock x:Name="ContactLbl" Text="" Foreground="#C8D8E4" FontSize="11" Margin="0,0,0,0" FontStyle="Italic"/>
        </StackPanel>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Учебные группы" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" FontSize="19" FontFamily="MV Boli"/>
        </Grid>

        <Grid Margin="0,45,0,0" Background="White">
            <Grid Width="3" Margin="200,0,0,0" Background="CadetBlue" HorizontalAlignment="Left"/>
            <Grid Height="3" Margin="200,0,0,37" Background="CadetBlue" VerticalAlignment="Bottom"/>

            <ScrollViewer Margin="0, 0, 0, 40" HorizontalAlignment="Left" Width="200" BorderBrush="White">
                <StackPanel Background="White">
                    <Button Content="📋 Списки ВПР" Click="OpenSpiski_BPR" 
        Foreground="White" Width="170" Height="30" 
        Background="CadetBlue" Margin="5"/>
                    <Button Content="📅 Расписание ВПР" Click="OpenRaspisanie_BPR" 
        Foreground="White" Width="170" Height="30" 
        Background="CadetBlue" Margin="5"/>
                    <Button Content="🔒 Ближайшие ВПР" Click="OpenClosed_BRP" 
        Foreground="White" Width="170" Height="30" 
        Background="CadetBlue" Margin="5"/>
                    <Button Content="📤 Экспорт/Импорт" Click="OpenExport" 
        Foreground="White" Width="170" Height="30" 
        Background="CadetBlue" Margin="5"/>
                    <Button Content="📚 Учебные предметы" Click="OpenLessons" 
        Foreground="White" Width="170" Height="30" 
        Background="CadetBlue" Margin="5"/>
                    <Button Content="🚪 Кабинеты" Click="OpenKabinets" 
        Foreground="White" Width="170" Height="30" 
        Background="CadetBlue" Margin="5"/>
                    <Button Content="👥 Группы" Click="OpenGroups" 
        Foreground="White" Width="170" Height="30" 
        Background="#2E8B57" Margin="5" FontWeight="Bold"/>
                    <Button Content="🏢 Отделения" Click="OpenDepartments" 
        Foreground="White" Width="170" Height="30" 
        Background="CadetBlue" Margin="5"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,10,10,0">
                <Label Content="Поиск по названию группы:" Foreground="Black" FontSize="12" FontFamily="MV Boli"/>
                <TextBox x:Name="searchTB" Width="150" Margin="0,0,5,0" TextChanged="SearchChanged" VerticalContentAlignment="Center"/>
                <ComboBox x:Name="deptFilterCB" Width="150" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="FilterChanged"/>
            </StackPanel>

            <ScrollViewer Margin="203, 40, 0, 40" BorderBrush="White">
                <StackPanel x:Name="GroupsParent" Background="White"/>
            </ScrollViewer>

            <Button Content="Добавить" HorizontalAlignment="Right" Click="AddGroups" Foreground="White" VerticalAlignment="Bottom" Width="100" Height="30" Background="CadetBlue" Margin="5"/>
            <Button Content="Вернуться к авторизации" HorizontalAlignment="Left" Click="OpenAuthorization" Foreground="White" VerticalAlignment="Bottom" Width="190" Height="30" Background="CadetBlue" Margin="5"/>
        </Grid>
    </Grid>
</Page>
