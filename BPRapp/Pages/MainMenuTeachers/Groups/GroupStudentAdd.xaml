<Page x:Class="BPRapp.Pages.MainMenuTeachers.Groups.GroupStudentAdd"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Студент группы">

    <Page.Resources>
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Color="#333333" Opacity="0.15" Direction="315"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C5D5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C5D5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                <ContentPresenter Content="{TemplateBinding Text}" Margin="6,0" VerticalAlignment="Center"/>
                            </Border>
                            <ToggleButton Grid.Column="1" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" HorizontalAlignment="Right" Width="24" Background="Transparent" BorderThickness="0">
                                <Path Data="M0,0 L4,4 L8,0 Z" Fill="{StaticResource DarkBlueBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="6" Height="4"/>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="1" CornerRadius="5" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource LightBlue}" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="White" CornerRadius="24" Width="48" Height="48" HorizontalAlignment="Left" Effect="{StaticResource CardShadow}">
                    <TextBlock Text="👥" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Добавить/Изменить студента" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="КГПАОУ Авиационный техникум имени А.Д. Швецова" FontSize="12" Foreground="#E6F2FF" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25">
            <Border Background="White" CornerRadius="12" Padding="25" Effect="{StaticResource CardShadow}" MaxWidth="600">
                <StackPanel>
                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="ФИО студента" FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,6"/>
                        <TextBox x:Name="fioTB" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="Пол" FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="polCB" Style="{StaticResource ModernComboBox}">
                            <ComboBoxItem Content="Мужской"/>
                            <ComboBoxItem Content="Женский"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Форма обучения" FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="formaCB" Style="{StaticResource ModernComboBox}">
                            <ComboBoxItem Content="Очная"/>
                            <ComboBoxItem Content="Заочная"/>
                        </ComboBox>
                    </StackPanel>
                    <Button x:Name="saveBtn" Click="SaveStudent" Content="💾 Сохранить" Style="{StaticResource ModernButton}" Width="180" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>