<Page x:Class="BPRapp.Pages.MainMenuTeachers.Groups.GroupStudentAdd"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Groups"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Студент группы">
    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Добавить/Изменить студента" Foreground="White" 
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" 
                   FontSize="19" FontFamily="MV Boli"/>
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Button Content="Назад" HorizontalAlignment="Left" Click="GoBack" 
                    Foreground="White" VerticalAlignment="Top" Width="60" Height="30" 
                    Background="CadetBlue" Margin="10,10,0,0"/>

            <StackPanel Margin="200, 50, 200, 0" Width="400">
                <Label Content="ФИО студента:" FontWeight="Bold"/>
                <TextBox x:Name="fioTB" Margin="0,5" Height="30" 
                         Background="White" BorderBrush="Black" BorderThickness="1"/>

                <Label Content="Пол:" FontWeight="Bold" Margin="0,15,0,0"/>
                <ComboBox x:Name="polCB" Margin="0,5" Height="30"
                          Background="White" BorderBrush="Black" BorderThickness="1">
                    <ComboBoxItem Content="Мужской"/>
                    <ComboBoxItem Content="Женский"/>
                </ComboBox>

                <Label Content="Форма обучения:" FontWeight="Bold" Margin="0,15,0,0"/>
                <ComboBox x:Name="formaCB" Margin="0,5" Height="30"
                          Background="White" BorderBrush="Black" BorderThickness="1">
                    <ComboBoxItem Content="Очная"/>
                    <ComboBoxItem Content="Заочная"/>
                </ComboBox>

                <Button x:Name="saveBtn" Click="SaveStudent" 
                        Content="Сохранить" Margin="0,30" Height="35" 
                        Background="CadetBlue" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>