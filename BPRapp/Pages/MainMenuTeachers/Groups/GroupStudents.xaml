<Page x:Class="BPRapp.Pages.MainMenuTeachers.Groups.GroupStudents"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Groups"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"  
      Title="Студенты группы">
    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label x:Name="TitleLbl" Content="Студенты группы" Foreground="White" 
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" 
                   FontSize="19" FontFamily="MV Boli"/>
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Label x:Name="CountLbl" Content="Всего: 0" Margin="10,10,0,0" FontWeight="Bold"/>

            <ScrollViewer Margin="0,40,0,40">
                <StackPanel x:Name="ListParent"/>
            </ScrollViewer>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10">
                <Button Content="Назад" Click="GoBack" 
                        Width="100" Height="30" Background="CadetBlue" 
                        Foreground="White" Margin="0,0,10,0"/>
                <Button Content="Добавить студента" Click="AddStudent" 
                        Width="150" Height="30" Background="CadetBlue" 
                        Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>