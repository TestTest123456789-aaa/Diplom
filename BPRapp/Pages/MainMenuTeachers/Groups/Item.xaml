<UserControl x:Class="BPRapp.Pages.MainMenuTeachers.Groups.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Groups"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="5">
        <Border BorderBrush="CadetBlue" BorderThickness="1" Background="White" CornerRadius="20" VerticalAlignment="Top" Height="135">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="5" Opacity="0.5"/>
            </Border.Effect>
            <Grid Margin="10, 3, 10, 10">
                <Button Content="Изменить" HorizontalAlignment="Left" VerticalAlignment="Top" Width="68" Height="25" BorderBrush="Green" Background="Green" Foreground="White" FontWeight="Bold" Click="EditGroup" Margin="0,26,0,0"/>
                <Button Content="Удалить" HorizontalAlignment="Left" VerticalAlignment="Top" Width="68" Height="25" BorderBrush="#E41613" Background="#E41613" Foreground="White" FontWeight="Bold" Margin="0,56,0,0" Click="DeleteGroup"/>
                <Button Content="Студенты группы" HorizontalAlignment="Left" VerticalAlignment="Top" Width="115" Height="25" BorderBrush="CadetBlue" Background="CadetBlue" Foreground="White" FontWeight="Bold" Margin="0,88,0,0" Click="OpenStudents"/>

                <Grid Margin="125,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0">
                        <Label Content="Название:" VerticalAlignment="Top"/>
                        <TextBox x:Name="nameTB" IsEnabled="False" Height="25" VerticalContentAlignment="Center" Padding="5,0" Margin="0,2"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0">
                        <Label Content="Руководитель:" VerticalAlignment="Top"/>
                        <TextBox x:Name="headTB" IsEnabled="False" Height="25" VerticalContentAlignment="Center" Padding="5,0" Margin="0,2"/>
                    </StackPanel>
                    <StackPanel Grid.Column="0" Grid.Row="1">
                        <Label Content="Отделение:" VerticalAlignment="Top"/>
                        <TextBox x:Name="deptTB" IsEnabled="False" Height="25" VerticalContentAlignment="Center" Padding="5,0" Margin="0,2"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="1">
                        <Label Content="Специальность:" VerticalAlignment="Top"/>
                        <TextBox x:Name="specTB" IsEnabled="False" Height="25" VerticalContentAlignment="Center" Padding="5,0" Margin="0,2"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>