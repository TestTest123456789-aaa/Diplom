<UserControl x:Class="BPRapp.Pages.MainMenuTeachers.Specialties.SpecialtyItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Specialties"
             mc:Ignorable="d" 
              d:DesignHeight="70" d:DesignWidth="900">
    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Color="#333333" Opacity="0.15" Direction="315"/>
    </UserControl.Resources>
    <Grid Margin="5">
        <Border Background="White" CornerRadius="12" Padding="15" BorderBrush="#C5D5E5" BorderThickness="1" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Код:" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="codeTB" Text="" FontSize="14" FontWeight="Bold" Foreground="#2E5C8A"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="20,0" VerticalAlignment="Center">
                    <TextBlock Text="Название:" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="nameTB" Text="" FontSize="14" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="✏️" Click="EditSpecialty" Width="34" Height="28" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="🗑️" Click="DeleteSpecialty" Width="34" Height="28" Background="#F44336" Foreground="White" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>