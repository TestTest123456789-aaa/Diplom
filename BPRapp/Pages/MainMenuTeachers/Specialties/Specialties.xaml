<Page x:Class="BPRapp.Pages.MainMenuTeachers.Specialties.Specialties"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Specialties"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Специальности">
    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Специальности" Foreground="White"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom"
                   FontSize="19" FontFamily="MV Boli"/>
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Grid Height="3" Margin="0,0,0,37" Background="CadetBlue" VerticalAlignment="Bottom"/>
            <Label x:Name="deptNameLabel" Content="" Margin="10,10,0,0"
                   VerticalAlignment="Top" HorizontalAlignment="Left" FontWeight="Bold" FontSize="14"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,10,10,0">
                <TextBox x:Name="searchTB" Width="300" Height="30" 
                         VerticalContentAlignment="Center" 
                         Padding="10,0"
                         FontSize="13"
                         TextChanged="SearchTB_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="White" BorderBrush="CadetBlue" BorderThickness="1.5" CornerRadius="5">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <TextBlock Text="🔍 Поиск специальности..." 
                           VerticalAlignment="Center" 
                           Margin="10,0,0,0" 
                           Foreground="Gray"
                           FontSize="13"/>
            </StackPanel>

            <ScrollViewer Margin="0, 90, 0, 40" BorderBrush="White">
                <StackPanel x:Name="SpecialtiesParent" Background="White"/>
            </ScrollViewer>

            <Button Content="Добавить" HorizontalAlignment="Right" Click="AddSpecialty" 
                Foreground="White" VerticalAlignment="Bottom" Width="100" Height="30" 
                Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
            <Button Content="Назад" HorizontalAlignment="Left" Click="GoBack" 
                Foreground="White" VerticalAlignment="Bottom" Width="100" Height="30" 
                Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
        </Grid>
    </Grid>
</Page>
