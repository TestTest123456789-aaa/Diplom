<Page x:Class="BPRapp.Pages.MainMenuTeachers.Specialties.Specialties"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Specialties"
      mc:Ignorable="d"
      d:DesignHeight="750" d:DesignWidth="1200"
      Title="Специальности">

    <Page.Resources>
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" 
                          Color="#333333" Opacity="0.15" Direction="315"/>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource LightBlue}" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔷 Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="White" CornerRadius="24" Width="48" Height="48" 
                        HorizontalAlignment="Left" Effect="{StaticResource CardShadow}">
                    <TextBlock Text="🎓" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Специальности" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="deptNameLabel" Text="" FontSize="14" 
                               Foreground="#E6F2FF" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Кнопка Назад -->
                <Button Content="← Назад к отделениям" Click="GoBack"
                        Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,20,0"
                        Width="150" Height="35" Background="White" 
                        Foreground="{StaticResource DarkBlueBrush}" FontSize="13" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" 
                                    BorderThickness="1" BorderBrush="White">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- 📋 Основное содержимое -->
        <Grid Grid.Row="1" Margin="30">
            <Border Style="{StaticResource SectionCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Поиск -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                        <TextBox x:Name="searchTB" Width="250" Height="30"
                                 VerticalContentAlignment="Center" Padding="10,0" FontSize="13"
                                 TextChanged="SearchTB_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="White" BorderBrush="{StaticResource PrimaryBlueBrush}" 
                                                        BorderThickness="1.5" CornerRadius="5">
                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <TextBlock Text="🔍 Поиск специальности..." VerticalAlignment="Center"
                                   Margin="10,0,0,0" Foreground="Gray" FontSize="13"/>
                    </StackPanel>

                    <!-- Список -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                        <StackPanel x:Name="SpecialtiesParent" Background="Transparent"/>
                    </ScrollViewer>

                    <!-- Кнопка Добавить -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="➕ Добавить" Click="AddSpecialty" Width="130" Height="35"
                                Background="{StaticResource PrimaryBlueBrush}" Foreground="White"
                                FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>