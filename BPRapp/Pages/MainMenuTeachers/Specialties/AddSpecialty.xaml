<Page x:Class="BPRapp.Pages.MainMenuTeachers.Specialties.AddSpecialty"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Specialties"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Специальность">
    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Специальность" Foreground="White" 
               HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" 
               FontSize="19" FontFamily="MV Boli"/>
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Button Content="Назад" HorizontalAlignment="Left" Click="GoBack" 
                Foreground="White" VerticalAlignment="Top" Width="60" Height="30" 
                Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="10,10,0,0"/>

            <Label Content="Код специальности:" Margin="0,0,250,150" 
               VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="codeTB" HorizontalAlignment="Center" Margin="0,0,0,100" 
                 Width="400" Height="32" Background="White" BorderBrush="Black" 
                 BorderThickness="1" VerticalAlignment="Center"/>

            <Label Content="Название специальности:" Margin="0,50,200,0" 
               VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="nameTB" HorizontalAlignment="Center" Margin="0,100,0,0" 
                 Width="400" Height="32" Background="White" BorderBrush="Black" 
                 BorderThickness="1" VerticalAlignment="Center" TextWrapping="Wrap"/>

            <Button x:Name="BthAdd" Click="SaveSpecialty" Content="Сохранить" 
                HorizontalAlignment="Center" Margin="0,180,0,0" Foreground="White" 
                VerticalAlignment="Center" Width="200" Height="31" 
                Background="CadetBlue" BorderBrush="Black" BorderThickness="1"/>
        </Grid>
    </Grid>
</Page>
