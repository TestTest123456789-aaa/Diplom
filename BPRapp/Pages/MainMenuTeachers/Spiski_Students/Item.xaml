<UserControl x:Class="BPRapp.Pages.MainMenuTeachers.Spiski_Students.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Spiski_Students"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="1200">
    <UserControl.Resources>
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Color="#333333" Opacity="0.15" Direction="315"/>
    </UserControl.Resources>
    <Grid Margin="5">
        <Border Background="White" CornerRadius="10" Padding="10" BorderBrush="#C5D5E5" BorderThickness="1" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,5,0">
                    <Button Click="EditStudent" Width="30" Height="28" Background="White" BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="1.5" Margin="0,0,4,0" ToolTip="Редактировать">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Image Source="/Images/pencil.png" Width="16" Height="16"/>
                    </Button>
                    <Button Click="DeleteStudent" Width="30" Height="28" Background="White" BorderBrush="#F44336" BorderThickness="1.5" ToolTip="Удалить">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Image Source="/Images/Delete.png" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="35*"/>
                        <ColumnDefinition Width="25*"/>
                        <ColumnDefinition Width="30*"/>
                        <ColumnDefinition Width="50*"/>
                        <ColumnDefinition Width="35*"/>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="35*"/>
                        <ColumnDefinition Width="30*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="№Пакета" FontWeight="SemiBold" FontSize="10" Foreground="#666"/>
                        <TextBox x:Name="nomer_paketaTB" IsEnabled="False" Height="24" Padding="6,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Пол" FontWeight="SemiBold" FontSize="10" Foreground="#666"/>
                        <TextBox x:Name="polTB" IsEnabled="False" Height="24" Padding="6,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Код" FontWeight="SemiBold" FontSize="10" Foreground="#666"/>
                        <TextBox x:Name="kodTB" IsEnabled="False" Height="24" Padding="6,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="ФИО" FontWeight="SemiBold" FontSize="10" Foreground="#666"/>
                        <TextBox x:Name="FIOTB" IsEnabled="False" Height="24" Padding="6,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Отметка" FontWeight="SemiBold" FontSize="10" Foreground="#666"/>
                        <TextBox x:Name="otmetka_ov_otsytstviiTB" IsEnabled="False" Height="24" Padding="6,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="5">
                        <TextBlock Text="Ср. балл" FontWeight="SemiBold" FontSize="10" Foreground="#666"/>
                        <TextBox x:Name="sredniy_ball_attestataTB" IsEnabled="False" Height="24" Padding="6,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Рус. язык" FontWeight="SemiBold" FontSize="10" Foreground="#666"/>
                        <TextBox x:Name="otsenka_po_russkomy_yazikyTB" IsEnabled="False" Height="24" Padding="6,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="7">
                        <TextBlock Text="Матем." FontWeight="SemiBold" FontSize="10" Foreground="#666"/>
                        <TextBox x:Name="otsenka_po_matematikeTB" IsEnabled="False" Height="24" Padding="6,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="8">
                        <TextBlock Text="Форма" FontWeight="SemiBold" FontSize="10" Foreground="#666"/>
                        <TextBox x:Name="forma_obychenyaTB" IsEnabled="False" Height="24" Padding="6,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="9">
                        <TextBlock Text="Группа" FontWeight="SemiBold" FontSize="10" Foreground="#666"/>
                        <TextBox x:Name="group_nameTB" IsEnabled="False" Height="24" Padding="6,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
