<UserControl x:Class="BPRapp.Pages.MainMenuTeachers.Spiski_Students.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Spiski_Students"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border BorderBrush="CadetBlue" BorderThickness="1" Background="White" VerticalAlignment="Top" Height="60">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="5" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Button Click ="EditStudent" VerticalAlignment="Top" Width="25" Height="25" Background="White" BorderBrush="CadetBlue" BorderThickness="2" Margin="5,26,0,0" HorizontalAlignment="Left">
                    <Image Source="/Images/pencil.png"/>
                </Button>
                <Button Click ="DeleteStudent" VerticalAlignment="Top" Width="25" Height="25" Background="White" BorderBrush="Red" BorderThickness="2" Margin="40,26,0,0" HorizontalAlignment="Left">
                    <Image Source="/Images/Delete.png"/>
                </Button>

                <Grid Margin="70,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="35*"/>
                        <ColumnDefinition Width="25*"/>
                        <ColumnDefinition Width="30*"/>
                        <ColumnDefinition Width="50*"/>
                        <ColumnDefinition Width="35*"/>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="35*"/>
                        <ColumnDefinition Width="30*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="№Пакета" Margin="0,0,0,0" VerticalAlignment="Top"/>
                    <TextBox x:Name="nomer_paketaTB" IsEnabled="False" Margin="0,26,0,0" Height="25" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10,0">
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                    <Label Content="Пол" Margin="0,0,0,0" VerticalAlignment="Top" Grid.Column="1"/>
                    <TextBox x:Name="polTB" IsEnabled="False" Margin="0,26,0,0" Height="25" Grid.Column="1" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10, 0">
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                    <Label Content="Код" Margin="0,0,0,0" VerticalAlignment="Top" Grid.Column="2"/>
                    <TextBox x:Name="kodTB" IsEnabled="False" Margin="0,26,0,0" Height="25" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10, 0" Grid.Column="2">
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                    <Label Content="ФИО" Margin="0,0,0,0" VerticalAlignment="Top" Grid.Column="3"/>
                    <TextBox x:Name="FIOTB" IsEnabled="False" Margin="0,26,0,0" Height="25" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10, 0" Grid.Column="3">
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                    <Label Content="Отметка об отсутсвии" Margin="0,0,0,0" VerticalAlignment="Top" Grid.Column="4"/>
                    <TextBox x:Name="otmetka_ov_otsytstviiTB" IsEnabled="False" Margin="0,26,0,0" Height="25" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10, 0" Grid.Column="4">
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                    <Label Content="Средний балл аттестата" Margin="0,0,0,0" VerticalAlignment="Top" Grid.Column="5"/>
                    <TextBox x:Name="sredniy_ball_attestataTB" IsEnabled="False" Margin="0,26,0,0" Height="25" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10, 0" Grid.Column="5">
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                    <Label Content="Оценка по русскому языку" Margin="0,0,0,0" VerticalAlignment="Top" Grid.Column="6"/>
                    <TextBox x:Name="otsenka_po_russkomy_yazikyTB" IsEnabled="False" Margin="0,26,0,0" Height="25" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10, 0" Grid.Column="6">
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                    <Label Content="Оценка по математике" Margin="0,0,0,0" VerticalAlignment="Top" Grid.Column="7"/>
                    <TextBox x:Name="otsenka_po_matematikeTB" IsEnabled="False" Margin="0,26,0,0" Height="25" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10, 0" Grid.Column="7">
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                    <Label Content="Форма обучения" Margin="0,0,0,0" VerticalAlignment="Top" Grid.Column="8"/>
                    <TextBox x:Name="forma_obychenyaTB" IsEnabled="False" Margin="0,26,0,0" Height="25" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10, 0" Grid.Column="8">
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                    <Label Content="Группа" Margin="0,0,0,0" VerticalAlignment="Top" Grid.Column="9"/>
                    <TextBox x:Name="group_nameTB" IsEnabled="False" Margin="0,26,0,0" Height="25" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10, 0" Grid.Column="9">
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
