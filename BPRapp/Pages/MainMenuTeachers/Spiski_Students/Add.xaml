<Page x:Class="BPRapp.Pages.MainMenuTeachers.Spiski_Students.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Spiski_Students"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Добавление студента">

    <Page.Resources>
        <!-- Корпоративные цвета КГПАОУ Авиационный техникум имени А.Д. Швецова -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>

        <!-- Стили для элементов управления -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource DarkBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"/>
                            </Border>
                            <ToggleButton HorizontalAlignment="Right"
                                        Background="Transparent"
                                        BorderThickness="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource LightBlueBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок страницы -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Декоративный элемент - иконка -->
                <Border Background="White" CornerRadius="20" Width="40" Height="40" HorizontalAlignment="Left">
                    <TextBlock Text="📝" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Добавление студента в список"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="КГПАОУ Авиационный техникум имени А.Д. Швецова"
                               FontSize="12"
                               Foreground="#E0E0E0"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <Border Background="White" CornerRadius="10" Padding="30">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Левая колонка -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,15">
                        <TextBlock Text="Основная информация" Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>
                        <Border Background="{StaticResource LightBlueBrush}" CornerRadius="5" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Номер пакета:" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="nomer_paketaTB" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                                <TextBlock Text="Пол студента:" Style="{StaticResource SectionLabel}"/>
                                <ComboBox x:Name="polTB" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15">
                                    <ComboBoxItem Content="Мужской"/>
                                    <ComboBoxItem Content="Женский"/>
                                </ComboBox>

                                <TextBlock Text="Код студента:" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="kodTB" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                                <TextBlock Text="Выберите студента:" Style="{StaticResource SectionLabel}"/>
                                <ComboBox x:Name="studentCB"
                                          Style="{StaticResource ModernComboBox}"
                                          Margin="0,0,0,15"
                                          DisplayMemberPath="FIO"
                                          SelectedValuePath="Id"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"/>

                                <TextBlock Text="Отметка об отсутствии:" Style="{StaticResource SectionLabel}"/>
                                <ComboBox x:Name="otmetka_ov_otsytstviiTB" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15">
                                    <ComboBoxItem Content="Присутствовал"/>
                                    <ComboBoxItem Content="Отсутствовал"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Правая колонка -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="20,0,0,15">
                        <TextBlock Text="Академические данные" Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>
                        <Border Background="{StaticResource LightBlueBrush}" CornerRadius="5" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Оценка по русскому языку:" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="otsenka_po_russkomy_yazikyTB" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                                <TextBlock Text="Оценка по математике:" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="otsenka_po_matematikeTB" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                                <TextBlock Text="Средний балл аттестата:" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="sredniy_ball_attestataTB" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                                <TextBlock Text="Форма обучения:" Style="{StaticResource SectionLabel}"/>
                                <ComboBox x:Name="forma_obychenyaTB" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15">
                                    <ComboBoxItem Content="Очная"/>
                                    <ComboBoxItem Content="Заочная"/>
                                </ComboBox>

                                <TextBlock Text="Группа:" Style="{StaticResource SectionLabel}"/>
                                <ComboBox x:Name="group_nameTB" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>

        <!-- Нижняя панель с кнопками -->
        <Border Grid.Row="2" Background="White" Padding="20,15" BorderBrush="{StaticResource LightBlueBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Content="← Назад"
                        Click="GoBackSpisok_Students"
                        Style="{StaticResource ModernButton}"
                        Width="120"
                        HorizontalAlignment="Left"/>

                <Button x:Name="BthAdd"
                        Click="AddStudent_info"
                        Content="Добавить запись"
                        Style="{StaticResource ModernButton}"
                        Width="180"
                        Grid.Column="2"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Page>