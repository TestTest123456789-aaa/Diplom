<Page x:Class="BPRapp.Pages.MainMenuTeachers.Spiski_Students.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Spiski_Students"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Добавление студента">

    <Page.Resources>
        <!-- Корпоративные цвета КГПАОУ Авиационный техникум имени А.Д. Швецова -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#4A90E2"/>
        <SolidColorBrush x:Key="LightBlue" Color="#6FA8DC"/>
        <SolidColorBrush x:Key="VeryLightBlue" Color="#E8F4FD"/>
        <SolidColorBrush x:Key="White" Color="#FFFFFF"/>

        <!-- Стили для элементов управления -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBlue}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LightBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBlue}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBlue}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <ContentPresenter x:Name="ContentSite"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Right"
                                          Width="20">
                                <Path Data="M0,0 L4,4 L8,0 Z" Fill="{StaticResource PrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="{StaticResource LightBlue}"
                                        BorderThickness="1.5" CornerRadius="3">
                                    <ScrollViewer MaxHeight="200">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource VeryLightBlue}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок страницы -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlue}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Style="{StaticResource ModernButton}"
                        Content="← Назад"
                        Click="GoBackSpisok_Students"
                        Width="100" Height="35"
                        HorizontalAlignment="Left"/>

                <TextBlock Grid.Column="1"
                           Text="Добавить студента в список"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Основная форма -->
        <Border Grid.Row="1" Background="White" Margin="20" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>

            <Grid Margin="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Левая колонка -->
                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,15,15">
                    <Label Style="{StaticResource ModernLabel}" Content="Номер пакета:"/>
                    <TextBox x:Name="nomer_paketaTB" Style="{StaticResource ModernTextBox}" Height="35"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,15,15">
                    <Label Style="{StaticResource ModernLabel}" Content="Пол студента:"/>
                    <ComboBox x:Name="polTB" Style="{StaticResource ModernComboBox}" Height="35">
                        <ComboBoxItem Content="Мужской"/>
                        <ComboBoxItem Content="Женский"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,15,15">
                    <Label Style="{StaticResource ModernLabel}" Content="Код студента:"/>
                    <TextBox x:Name="kodTB" Style="{StaticResource ModernTextBox}" Height="35"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,0,15,15">
                    <Label Style="{StaticResource ModernLabel}" Content="Студент:"/>
                    <ComboBox x:Name="studentCB"
                              Style="{StaticResource ModernComboBox}"
                              Height="35"
                              DisplayMemberPath="FIO"
                              SelectedValuePath="Id"
                              IsEditable="True"
                              IsTextSearchEnabled="True"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="4" Margin="0,0,15,15">
                    <Label Style="{StaticResource ModernLabel}" Content="Отметка об отсутствии:"/>
                    <ComboBox x:Name="otmetka_ov_otsytstviiTB" Style="{StaticResource ModernComboBox}" Height="35">
                        <ComboBoxItem Content="Присутствовал"/>
                        <ComboBoxItem Content="Отсутствовал"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="5" Margin="0,0,15,15">
                    <Label Style="{StaticResource ModernLabel}" Content="Средний балл аттестата:"/>
                    <TextBox x:Name="sredniy_ball_attestataTB" Style="{StaticResource ModernTextBox}" Height="35"/>
                </StackPanel>

                <!-- Правая колонка -->
                <StackPanel Grid.Column="1" Grid.Row="0" Margin="15,0,0,15">
                    <Label Style="{StaticResource ModernLabel}" Content="Оценка по русскому языку:"/>
                    <TextBox x:Name="otsenka_po_russkomy_yazikyTB" Style="{StaticResource ModernTextBox}" Height="35"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="1" Margin="15,0,0,15">
                    <Label Style="{StaticResource ModernLabel}" Content="Оценка по математике:"/>
                    <TextBox x:Name="otsenka_po_matematikeTB" Style="{StaticResource ModernTextBox}" Height="35"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="2" Margin="15,0,0,15">
                    <Label Style="{StaticResource ModernLabel}" Content="Форма обучения:"/>
                    <ComboBox x:Name="forma_obychenyaTB" Style="{StaticResource ModernComboBox}" Height="35">
                        <ComboBoxItem Content="Очная"/>
                        <ComboBoxItem Content="Заочная"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="3" Margin="15,0,0,15">
                    <Label Style="{StaticResource ModernLabel}" Content="Группа:"/>
                    <ComboBox x:Name="group_nameTB" Style="{StaticResource ModernComboBox}" Height="35"/>
                </StackPanel>

                <!-- Кнопка добавления -->
                <Button x:Name="BthAdd"
                        Click="AddStudent_info"
                        Content="Добавить новую запись"
                        Style="{StaticResource ModernButton}"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Grid.Row="7"
                        HorizontalAlignment="Center"
                        Width="250"
                        Height="45"
                        Margin="0,20,0,0"
                        FontSize="16"/>
            </Grid>
        </Border>
    </Grid>
</Page>