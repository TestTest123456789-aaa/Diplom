<Page x:Class="BPRapp.Pages.MainMenuTeachers.Spiski_Students.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Spiski_Students"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Добавить студента в список" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" Margin="0,0,0,0" FontSize="19" FontFamily="MV Boli" Grid.Column="1" />
        </Grid>

        <Grid Margin="0,45,0,0" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*"/>
                <ColumnDefinition Width="50*"/>
            </Grid.ColumnDefinitions>
            <Button Content="Назад" HorizontalAlignment="Left" Click="GoBackSpisok_Students" Foreground="White"  VerticalAlignment="Top" Width="60" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="10,10,0,0"/>
            <Label Content="Укажите Номер пакета:" Margin="10,40,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Grid.Column="0"/>
            <TextBox x:Name="nomer_paketaTB" Margin="10,62,10,0" Height="30" Background="White" BorderBrush="Black" Grid.Column="0" BorderThickness="1" VerticalAlignment="Top"/>
            <Label Content="Укажите пол студента:" Margin="10,90,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Grid.Column="0"/>
            <ComboBox x:Name="polTB" Margin="10,112,10,0" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Top" Grid.Column="0">
                <ComboBoxItem Content="Мужской"/>
                <ComboBoxItem Content="Женский"/>
            </ComboBox>
            <Label Content="Укажите код студента:" Margin="10,140,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26"/>
            <TextBox x:Name="kodTB" Margin="10,162,10,0" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Top" Grid.Column="0"/>
            <Label Content="Выберите студента:" Margin="10,190,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Grid.Column="0"/>
            <ComboBox x:Name="studentCB" Margin="10,212,10,0" Height="32" 
          Background="White" BorderBrush="Black" BorderThickness="1" 
          VerticalAlignment="Top" Grid.Column="0" 
          DisplayMemberPath="FIO" SelectedValuePath="Id" 
          IsEditable="True" IsTextSearchEnabled="True"
          Text=""/>
            <Label Content="Отметка об отсутствии:" Margin="10,240,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Grid.Column="0"/>
            <ComboBox x:Name="otmetka_ov_otsytstviiTB" Margin="10,262,10,0" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Top" Grid.Column="0">
                <ComboBoxItem Content="Присутствовал"/>
                <ComboBoxItem Content="Отсутствовал"/>
            </ComboBox>
            <Label Content="Средний балл аттестата:" Margin="10,290,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Grid.Column="0"/>
            <TextBox x:Name="sredniy_ball_attestataTB" Margin="10,312,10,0" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Top" Grid.Column="0"/>
            <Label Content="Оценка по русскому языку:" Margin="10,40,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Grid.Column="1"/>
            <TextBox x:Name="otsenka_po_russkomy_yazikyTB" Margin="10,62,10,0" Height="30" Background="White" BorderBrush="Black" Grid.Column="1" BorderThickness="1" VerticalAlignment="Top"/>
            <Label Content="Оценка по математике:" Margin="10,90,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Grid.Column="1"/>
            <TextBox x:Name="otsenka_po_matematikeTB" Margin="10,112,10,0" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Top" Grid.Column="1"/>
            <Label Content="Укажите Форму обучения студента:" Margin="10,140,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Grid.Column="1"/>
            <ComboBox x:Name="forma_obychenyaTB" Margin="10,162,10,0" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Top" Grid.Column="1">
                <ComboBoxItem Content="Очная"/>
                <ComboBoxItem Content="Заочная"/>
            </ComboBox>
            <Label Content="Группа:" Margin="10,190,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Grid.Column="1"/>
            <ComboBox x:Name="group_nameTB" Margin="10,212,10,0" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Top" Grid.Column="1"/>
            <Button x:Name="BthAdd" Click="AddStudent_info" Content="Добавить новую запись" HorizontalAlignment="Center" Margin="0,352,0,0" Foreground="White" VerticalAlignment="Top" Width="200" Height="31" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Grid.ColumnSpan="2"/>
        </Grid>
    </Grid>
</Page>
