<Page x:Class="BPRapp.Pages.MainMenuTeachers.Kabinets.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Kabinets"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">
    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Добавить кабинет" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" FontSize="19" FontFamily="MV Boli"/>
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Button Content="Назад" HorizontalAlignment="Left" Click="GoBack" Foreground="White" VerticalAlignment="Top" Width="60" Height="30" Background="CadetBlue" Margin="10,10,0,0"/>
            <StackPanel Margin="200, 50, 200, 0" Width="400">
                <Label Content="Название кабинета:"/>
                <TextBox x:Name="nameTB" Margin="0,5" Height="30"/>
                <Label Content="Количество мест:"/>
                <TextBox x:Name="capacityTB" Margin="0,5" Height="30"/>
                <Button x:Name="BthAdd" Click="SaveKabinet" Content="Сохранить" Margin="0,20" Height="35" Background="CadetBlue" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>