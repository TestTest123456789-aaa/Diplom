<Page x:Class="BPRapp.Pages.MainMenuTeachers.MainMenuTeachers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainMenuTeachers">

    <Grid>
        <StackPanel x:Name="UserInfoPanel" Margin="10,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Panel.ZIndex="100">
            <TextBlock x:Name="FioLbl" Text="" FontWeight="Bold" Foreground="White" FontSize="14"/>
            <TextBlock x:Name="ContactLbl" Text="" Foreground="#C8D8E4" FontSize="11" Margin="0,0,0,0" FontStyle="Italic"/>
        </StackPanel>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Списки ВПР" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" Margin="0,0,0,0" FontSize="19" FontFamily="MV Boli" Grid.Column="1" />
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Grid Width="3" Margin="200,0,0,0" Background="CadetBlue" HorizontalAlignment="Left"/>
            <ScrollViewer Margin="0, 0, 0, 40" HorizontalAlignment="Left" Width="200" BorderBrush="White">
                <StackPanel Background="White">
                    <Button Content="📋 Списки ВПР" Click="OpenSpiski_BPR" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="📅 Расписание ВПР" Click="OpenRaspisanie_BPR" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="🔒 Ближайшие ВПР" Click="OpenClosed_BRP" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="📤 Экспорт/Импорт" Click="OpenExport" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="📚 Учебные предметы" Click="OpenLessons" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="🚪 Кабинеты" Click="OpenKabinets" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="👥 Группы" Click="OpenGroups" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                    <Button Content="🏢 Отделения" Click="OpenDepartments" 
Foreground="White" Width="170" Height="30" 
Background="CadetBlue" Margin="5"/>
                </StackPanel>
            </ScrollViewer>
            <Button Content="Вернуться к авторизации" HorizontalAlignment="Left" Click="OpenAuthorization" Foreground="White"  VerticalAlignment="Bottom" Width="190" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
        </Grid>
    </Grid>
</Page>