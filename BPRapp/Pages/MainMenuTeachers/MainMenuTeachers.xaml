<Page x:Class="BPRapp.Pages.MainMenuTeachers.MainMenuTeachers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Главное меню - Система ВПР"
      d:DesignHeight="600" d:DesignWidth="1000">

    <Page.Resources>
        <!-- 🎨 Корпоративные цвета -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>

        <!-- ✨ Тень -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" 
                          Color="#333333" Opacity="0.15" Direction="315"/>

        <!-- 🔘 Стиль кнопки меню -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="{StaticResource LightBlueBrush}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource LightBlueBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource LightBlue}" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔷 Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="White" CornerRadius="24" Width="48" Height="48" 
                        HorizontalAlignment="Left" Effect="{StaticResource CardShadow}">
                    <TextBlock Text="👨‍" FontSize="26" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Главное меню преподавателя"
                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="КГПАОУ Авиационный техникум имени А.Д. Швецова"
                               FontSize="12" Foreground="#E6F2FF" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Информация о пользователе -->
                <StackPanel x:Name="UserInfoPanel" Grid.Column="1" 
                            Margin="0,0,20,0" VerticalAlignment="Center" 
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="FioLbl" Text="" FontWeight="Bold" 
                               Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="ContactLbl" Text="" 
                               Foreground="#E6F2FF" FontSize="11" 
                               FontStyle="Italic"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 📋 Основное содержимое -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: Меню -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" 
                    Padding="15" Effect="{StaticResource CardShadow}">
                <Grid>
                    <!-- 🔹 ScrollViewer для прокрутки меню -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="📌 Разделы" FontSize="16" FontWeight="Bold" 
                                       Foreground="{StaticResource DarkBlueBrush}" 
                                       Margin="0,0,0,15"/>

                            <Button Content="📋 Списки ВПР" Click="OpenSpiski_BPR" 
                                    Style="{StaticResource MenuButton}"/>
                            <Button Content="📅 Расписание ВПР" Click="OpenRaspisanie_BPR" 
                                    Style="{StaticResource MenuButton}"/>
                            <Button Content="🔒 Ближайшие ВПР" Click="OpenClosed_BRP" 
                                    Style="{StaticResource MenuButton}"/>
                            <Button Content="📤 Экспорт/Импорт" Click="OpenExport" 
                                    Style="{StaticResource MenuButton}"/>
                            <Button Content="🔔 Настройки уведомлений" Click="OpenNotificationSettings" Style="{StaticResource MenuButton}"/>
                            <Separator Margin="5,10" Background="{StaticResource LightBlueBrush}"/>

                            <TextBlock Text="📚 Справочники" FontSize="16" FontWeight="Bold" 
                                       Foreground="{StaticResource DarkBlueBrush}" 
                                       Margin="0,0,0,15"/>

                            <Button Content="📚 Учебные предметы" Click="OpenLessons" 
                                    Style="{StaticResource MenuButton}"/>
                            <Button Content="🚪 Кабинеты" Click="OpenKabinets" 
                                    Style="{StaticResource MenuButton}"/>
                            <Button Content="👥 Группы" Click="OpenGroups" 
                                    Style="{StaticResource MenuButton}"/>
                            <Button Content="🏢 Отделения" Click="OpenDepartments" 
                                    Style="{StaticResource MenuButton}"/>

                            <Separator Margin="5,10" Background="{StaticResource LightBlueBrush}"/>

                            <!-- 🔹 Кнопка ВЫХОД -->
                            <Button Content="🚪 Выйти из системы" Click="OpenAuthorization" 
                                    Width="190" Height="45" Margin="5,5,5,15">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MenuButton}">
                                        <Setter Property="Background" Value="#FFE5E5"/>
                                        <Setter Property="Foreground" Value="#D32F2F"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFCDD2"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Правая панель: Приветствие -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" 
                    Padding="30" Margin="20,0,0,0" Effect="{StaticResource CardShadow}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="👋 Добро пожаловать!" FontSize="28" FontWeight="Bold" 
                               Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,10"/>
                    <TextBlock x:Name="WelcomeText" Text="" FontSize="16" 
                               Foreground="#666" Margin="0,0,0,20"/>

                    <Border Background="{StaticResource LightBlueBrush}" 
                            CornerRadius="10" Padding="20" Margin="0,10">
                        <StackPanel>
                            <TextBlock Text="💡 Быстрый доступ" FontSize="16" 
                                       FontWeight="Bold" Foreground="{StaticResource DarkBlueBrush}" 
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="• Используйте меню слева для навигации" 
                                       FontSize="13" Foreground="#555" Margin="0,5"/>
                            <TextBlock Text="• Все изменения автоматически сохраняются" 
                                       FontSize="13" Foreground="#555" Margin="0,5"/>
                            <TextBlock Text="• При возникновении вопросов обратитесь к администратору" 
                                       FontSize="13" Foreground="#555" Margin="0,5"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>