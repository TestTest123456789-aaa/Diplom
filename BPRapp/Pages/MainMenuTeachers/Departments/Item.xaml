<UserControl x:Class="BPRapp.Pages.MainMenuTeachers.Departments.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Departments"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="900">

    <UserControl.Resources>
        <!-- 🎨 Корпоративные цвета -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" 
                          Color="#333333" Opacity="0.15" Direction="315"/>
    </UserControl.Resources>

    <Grid Margin="5">
        <Border Background="White" CornerRadius="12" Padding="15"
                BorderBrush="#C5D5E5" BorderThickness="1"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Кнопки действий -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Button Content="✏️ Изменить" Click="EditDepartment"
                            Width="160" Height="30" Margin="0,0,0,8"
                            Background="#4CAF50" Foreground="White"
                            FontSize="12" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="🗑️ Удалить" Click="DeleteDepartment"
                            Width="160" Height="30" Margin="0,0,0,8"
                            Background="#F44336" Foreground="White"
                            FontSize="12" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="📚 Специальности" Click="OpenSpecialties"
                            Width="160" Height="30"
                            Background="{StaticResource PrimaryBlueBrush}" Foreground="White"
                            FontSize="12" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Информация об отделении -->
                <Grid Grid.Column="1" Margin="20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="📋 Название:" Grid.Row="0" Grid.Column="0"
                               FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,8"/>
                    <TextBox x:Name="nameTB" Grid.Row="0" Grid.Column="1"
                             IsEnabled="False" Height="28" Margin="0,0,0,8"
                             Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"
                             Padding="8,0" VerticalContentAlignment="Center"/>

                    <TextBlock Text="👨‍🏫 Заведующий:" Grid.Row="1" Grid.Column="0"
                               FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="headTB" Grid.Row="1" Grid.Column="1"
                             IsEnabled="False" Height="28"
                             Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"
                             Padding="8,0" VerticalContentAlignment="Center"/>
                </Grid>                
            </Grid>
        </Border>
    </Grid>
</UserControl>