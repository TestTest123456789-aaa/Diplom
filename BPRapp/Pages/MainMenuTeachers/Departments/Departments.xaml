<Page x:Class="BPRapp.Pages.MainMenuTeachers.Departments.Departments"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Departments"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Departments">

    <Grid>
        <StackPanel x:Name="UserInfoPanel" Margin="10,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Panel.ZIndex="100">
            <TextBlock x:Name="FioLbl" Text="" FontWeight="Bold" Foreground="White" FontSize="14"/>
            <TextBlock x:Name="ContactLbl" Text="" Foreground="#C8D8E4" FontSize="11" Margin="0,0,0,0" FontStyle="Italic"/>
        </StackPanel>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Учебные отделения" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" Margin="0,0,0,0" FontSize="19" FontFamily="MV Boli" Grid.Column="1" />
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Grid Width="3" Margin="200,0,0,0" Background="CadetBlue" HorizontalAlignment="Left"/>
            <Grid Height="3" Margin="200,0,0,37" Background="CadetBlue" VerticalAlignment="Bottom"/>
            <ScrollViewer Margin="0, 0, 0, 40" HorizontalAlignment="Left" Width="200" BorderBrush="White">
                <StackPanel Background="White">
                    <Button Content="📋 Списки ВПР" HorizontalAlignment="Center" Click="OpenSpiski_BPR" Foreground="White" Width="170" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
                    <Button Content="📅 Расписание ВПР" HorizontalAlignment="Center" Click="OpenRaspisanie_BPR" Foreground="White" Width="170" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
                    <Button Content="🔒 Ближайшие ВПР" HorizontalAlignment="Center" Click="OpenClosed_BRP" Foreground="White" Width="170" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
                    <Button Content="📤 Экспорт/Импорт" HorizontalAlignment="Center" Click="OpenExport" Foreground="White" Width="170" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
                    <Button Content="📚 Учебные предметы" HorizontalAlignment="Center" Click="OpenLessons" Foreground="White" Width="170" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
                    <Button Content="🚪 Кабинеты" HorizontalAlignment="Center" Click="OpenKabinets" Foreground="White" Width="170" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
                    <Button Content="👥 Группы" HorizontalAlignment="Center" Click="OpenGroups" Foreground="White" Width="170" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
                    <Button Content="🏢 Отделения" FontWeight="Bold" HorizontalAlignment="Center" Click="OpenDepartments" Foreground="White" Width="170" Height="30" Background="#2E8B57" BorderBrush="Black" BorderThickness="1" Margin="5"/>
                </StackPanel>
            </ScrollViewer>

            <!-- 🔹 ПАНЕЛЬ ПОИСКА -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,10,10,0">
                <TextBox x:Name="searchTB" Width="250" Height="30" 
                         VerticalContentAlignment="Center" 
                         Padding="10,0"
                         FontSize="13"
                         TextChanged="SearchTB_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="White" BorderBrush="CadetBlue" BorderThickness="1.5" CornerRadius="5">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <TextBlock Text="🔍 Поиск отделения..." 
                           VerticalAlignment="Center" 
                           Margin="10,0,0,0" 
                           Foreground="Gray"
                           FontSize="13"/>
            </StackPanel>

            <ScrollViewer Margin="203, 50, 0, 40" BorderBrush="White">
                <StackPanel x:Name="DepartmentsParent" Background="White"/>
            </ScrollViewer>

            <Button Content="Добавить" HorizontalAlignment="Right" Click="AddDepartment" 
                Foreground="White" VerticalAlignment="Bottom" Width="100" Height="30" 
                Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
            <Button Content="Вернуться к авторизации" HorizontalAlignment="Left" Click="OpenAuthorization" 
                Foreground="White" VerticalAlignment="Bottom" Width="190" Height="30" 
                Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="5"/>
        </Grid>
    </Grid>
</Page>
