<Page x:Class="BPRapp.Pages.MainMenuTeachers.Export.Export"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Export"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
         Title="Экспорт/Импорт данных">

    <Grid>
        <StackPanel x:Name="UserInfoPanel" Margin="10,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Panel.ZIndex="100">
            <TextBlock x:Name="FioLbl" Text="" FontWeight="Bold" Foreground="White" FontSize="14"/>
            <TextBlock x:Name="ContactLbl" Text="" Foreground="#C8D8E4" FontSize="11" Margin="0,0,0,0" FontStyle="Italic"/>
        </StackPanel>

        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="📤 Экспорт / 📥 Импорт данных" Foreground="White" 
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" 
                   FontSize="19" FontFamily="MV Boli"/>
        </Grid>

        <Grid Margin="0,45,0,0" Background="White">
            <Grid Width="200" HorizontalAlignment="Left" Background="#F5F5F5">
                <ScrollViewer Margin="0,0,0,40">
                    <StackPanel>
                        <Button Content="📋 Списки ВПР" Click="OpenSpiski_BPR" 
                                Foreground="White" Width="170" Height="30" 
                                Background="CadetBlue" Margin="5"/>
                        <Button Content="📅 Расписание ВПР" Click="OpenRaspisanie_BPR" 
                                Foreground="White" Width="170" Height="30" 
                                Background="CadetBlue" Margin="5"/>
                        <Button Content="🔒 Ближайшие ВПР" Click="OpenClosed_BRP" 
                                Foreground="White" Width="170" Height="30" 
                                Background="CadetBlue" Margin="5"/>
                        <Button Content="📤 Экспорт/Импорт" Click="OpenExport" 
                                Foreground="White" Width="170" Height="30" 
                                Background="#2E8B57" FontWeight="Bold" Margin="5"/>
                        <Button Content="📚 Учебные предметы" Click="OpenLessons" 
                                Foreground="White" Width="170" Height="30" 
                                Background="CadetBlue" Margin="5"/>
                        <Button Content="🚪 Кабинеты" Click="OpenKabinets" 
                                Foreground="White" Width="170" Height="30" 
                                Background="CadetBlue" Margin="5"/>
                        <Button Content="👥 Группы" Click="OpenGroups" 
                                Foreground="White" Width="170" Height="30" 
                                Background="CadetBlue" Margin="5"/>
                        <Button Content="🏢 Отделения" Click="OpenDepartments" 
                                Foreground="White" Width="170" Height="30" 
                                Background="CadetBlue" Margin="5"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Margin="203,10,10,50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Выберите действие:" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                <StackPanel Grid.Row="1" VerticalAlignment="Top">

                    <GroupBox Header="📋 Экспорт списков ВПР" Margin="0,0,0,15" Padding="10">
                        <StackPanel>
                            <ComboBox x:Name="bprExportTypeCB" Margin="0,0,0,5">
                                <ComboBoxItem Content="Все ВПР" IsSelected="True"/>
                                <ComboBoxItem Content="Только мои ВПР"/>
                                <ComboBoxItem Content="Выбрать конкретный ВПР"/>
                            </ComboBox>

                            <ComboBox x:Name="bprListCB" Margin="0,0,0,5" 
                                      SelectedValuePath="Id"
                                      Visibility="Collapsed"
                                      HorizontalContentAlignment="Left">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock FontWeight="Bold" 
                                                       Text="{Binding Date, StringFormat='📅 {0}'}"/>
                                            <TextBlock Foreground="#555" FontSize="11"
                                                       Text="{Binding DisplayInfo}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="📊 Экспорт в Excel" Click="ExportBPRToExcel" 
                                        Width="150" Height="30" Background="#2E8B57" 
                                        Foreground="White" Margin="0,0,5,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="👥 Экспорт групп студентов" Margin="0,0,0,15" Padding="10">
                        <StackPanel>
                            <ComboBox x:Name="groupExportCB" Margin="0,0,0,5" 
                                      DisplayMemberPath="Name" SelectedValuePath="Id">
                                <ComboBoxItem Content="Все группы"/>
                            </ComboBox>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="📊 Экспорт в Excel" Click="ExportGroupsToExcel" 
                                        Width="150" Height="30" Background="#2E8B57" 
                                        Foreground="White" Margin="0,0,5,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="📥 Импорт студентов из Excel" Margin="0,0,0,15" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Выберите группу для импорта:" Margin="0,0,0,5"/>
                            <ComboBox x:Name="importGroupCB" Margin="0,0,0,5" 
                                      DisplayMemberPath="Name" SelectedValuePath="Id"/>
                            <Button Content="📁 Выбрать Excel-файл" Click="ImportStudentsFromExcel" 
                                    Width="200" Height="30" Background="#FF8C00" 
                                    Foreground="White"/>
                            <TextBlock x:Name="importStatusTB" Margin="0,5,0,0" 
                                       Foreground="#2E8B57" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="📋 Шаблоны для импорта" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Скачайте шаблон Excel для корректного импорта:" 
                                       Margin="0,0,0,5" TextWrapping="Wrap"/>
                            <Button Content="⬇️ Скачать шаблон студентов" Click="DownloadStudentTemplate" 
                                    Width="200" Height="30" Background="#696969" 
                                    Foreground="White"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <TextBlock x:Name="statusTB" Grid.Row="2" Margin="0,10,0,0" 
                           Foreground="#2E8B57" FontWeight="Bold"/>
            </Grid>

            <Button Content="🔙 Вернуться к авторизации" Click="OpenAuthorization" 
                    Foreground="White" VerticalAlignment="Bottom" Width="190" Height="30" 
                    Background="CadetBlue" Margin="208,5,5,5"/>
        </Grid>
    </Grid>
</Page>