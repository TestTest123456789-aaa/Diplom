<Page x:Class="BPRapp.Pages.MainMenuTeachers.Export.Export"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Export"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Экспорт/Импорт данных">

    <Page.Resources>
        <!-- 🎨 Корпоративные цвета -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>
        <Color x:Key="AccentBlue">#4A86C7</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>

        <!-- ✨ Тень для карточек -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" 
                          Color="#333333" Opacity="0.15" Direction="315"/>

        <!-- 🔘 Стиль кнопки меню -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="{StaticResource LightBlueBrush}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource LightBlueBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 📦 Стиль для блоков настроек (вместо GroupBox) -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- 🏷️ Стиль заголовка секции -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- 🔽 Стиль ComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C5D5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ContentPresenter Content="{TemplateBinding Text}" Margin="6,0" VerticalAlignment="Center"/>
                            </Border>
                            <ToggleButton Grid.Column="1" Focusable="false"
                                        IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                        ClickMode="Press" HorizontalAlignment="Right" Width="24"
                                        Background="Transparent" BorderThickness="0">
                                <Path Data="M0,0 L4,4 L8,0 Z" Fill="{StaticResource DarkBlueBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Width="6" Height="4"/>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="{StaticResource PrimaryBlueBrush}"
                                        BorderThickness="1" CornerRadius="5" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!-- 🎨 Градиентный фон -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource LightBlue}" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔷 Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="White" CornerRadius="24" Width="48" Height="48" 
                        HorizontalAlignment="Left" Effect="{StaticResource CardShadow}">
                    <TextBlock Text="📤" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Экспорт / Импорт данных" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="КГПАОУ Авиационный техникум имени А.Д. Швецова"
                               FontSize="12" Foreground="#E6F2FF" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Информация о пользователе -->
                <StackPanel x:Name="UserInfoPanel" Grid.Column="1" 
                            Margin="0,0,20,0" VerticalAlignment="Center" 
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="FioLbl" Text="" FontWeight="Bold" 
                               Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="ContactLbl" Text="" 
                               Foreground="#E6F2FF" FontSize="11" FontStyle="Italic"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 📋 Основное содержимое -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: Меню -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" 
                    Padding="15" Effect="{StaticResource CardShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="📌 Разделы" FontSize="16" FontWeight="Bold" 
                                   Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,15"/>

                        <Button Content="📋 Списки ВПР" Click="OpenSpiski_BPR" Style="{StaticResource MenuButton}"/>
                        <Button Content="📅 Расписание ВПР" Click="OpenRaspisanie_BPR" Style="{StaticResource MenuButton}"/>
                        <Button Content="🔒 Ближайшие ВПР" Click="OpenClosed_BRP" Style="{StaticResource MenuButton}"/>
                        <Button Content="📤 Экспорт/Импорт" Click="OpenExport" Style="{StaticResource MenuButton}"
                                Background="{StaticResource LightBlueBrush}" BorderBrush="{StaticResource PrimaryBlueBrush}"/>

                        <Separator Margin="5,10" Background="{StaticResource LightBlueBrush}"/>

                        <TextBlock Text="📚 Справочники" FontSize="16" FontWeight="Bold" 
                                   Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,15"/>

                        <Button Content="📚 Учебные предметы" Click="OpenLessons" Style="{StaticResource MenuButton}"/>
                        <Button Content="🚪 Кабинеты" Click="OpenKabinets" Style="{StaticResource MenuButton}"/>
                        <Button Content="👥 Группы" Click="OpenGroups" Style="{StaticResource MenuButton}"/>
                        <Button Content="🏢 Отделения" Click="OpenDepartments" Style="{StaticResource MenuButton}"/>

                        <Separator Margin="5,10" Background="{StaticResource LightBlueBrush}"/>

                        <!-- 🔹 Кнопка ВЫХОД -->
                        <Button Content="🚪 Выйти из системы" Click="OpenAuthorization" 
                                Width="190" Height="45" Margin="5,5,5,15">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MenuButton}">
                                    <Setter Property="Background" Value="#FFE5E5"/>
                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFCDD2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Правая панель: Функционал Экспорта/Импорта -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="20,0,0,0">
                <StackPanel>
                    <TextBlock Text="Выберите действие:" Style="{StaticResource SectionLabel}"/>

                    <!-- 🔹 Экспорт ВПР -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="📋 Экспорт списков ВПР" Style="{StaticResource SectionLabel}" FontSize="16"/>

                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="Тип экспорта:" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,5"/>
                                <ComboBox x:Name="bprExportTypeCB" Style="{StaticResource ModernComboBox}">
                                    <ComboBoxItem Content="Все ВПР" IsSelected="True"/>
                                    <ComboBoxItem Content="Только мои ВПР"/>
                                    <ComboBoxItem Content="Выбрать конкретный ВПР"/>
                                </ComboBox>
                            </StackPanel>

                            <ComboBox x:Name="bprListCB" Margin="0,0,0,15" Visibility="Collapsed"
                                      SelectedValuePath="Id" HorizontalContentAlignment="Left"
                                      Style="{StaticResource ModernComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock FontWeight="Bold" Text="{Binding Date, StringFormat='📅 {0}'}"/>
                                            <TextBlock Foreground="#555" FontSize="11" Text="{Binding DisplayInfo}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Button Content="📊 Экспорт в Excel" Click="ExportBPRToExcel"
                                    Width="180" Height="35" Background="{StaticResource PrimaryBlueBrush}" 
                                    Foreground="White" FontSize="14" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 🔹 Экспорт групп -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="👥 Экспорт групп студентов" Style="{StaticResource SectionLabel}" FontSize="16"/>

                            <ComboBox x:Name="groupExportCB" Margin="0,0,0,15" 
                                      DisplayMemberPath="Name" SelectedValuePath="Id"
                                      Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem Content="Все группы"/>
                            </ComboBox>

                            <Button Content="📊 Экспорт групп в Excel" Click="ExportGroupsToExcel"
                                    Width="180" Height="35" Background="{StaticResource PrimaryBlueBrush}" 
                                    Foreground="White" FontSize="14" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 🔹 Импорт -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="📥 Импорт студентов из Excel" Style="{StaticResource SectionLabel}" FontSize="16"/>

                            <TextBlock Text="Выберите группу для импорта:" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,5"/>
                            <ComboBox x:Name="importGroupCB" Margin="0,0,0,15" 
                                      DisplayMemberPath="Name" SelectedValuePath="Id"
                                      Style="{StaticResource ModernComboBox}"/>

                            <Button Content="📁 Выбрать Excel-файл" Click="ImportStudentsFromExcel"
                                    Width="180" Height="35" Background="#FF8C00" 
                                    Foreground="White" FontSize="14" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock x:Name="importStatusTB" Margin="0,10,0,0"
                                       Foreground="#2E8B57" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- 🔹 Шаблоны -->
                    <Border Style="{StaticResource SectionCard}" Background="#FFF9E6" BorderBrush="#FFD700">
                        <StackPanel>
                            <TextBlock Text="📋 Шаблоны для импорта" Style="{StaticResource SectionLabel}" FontSize="16" Foreground="#856404"/>

                            <TextBlock Text="Скачайте шаблон Excel для корректного импорта:" 
                                       Margin="0,0,0,15" TextWrapping="Wrap" Foreground="#666"/>

                            <Button Content="⬇️ Скачать шаблон студентов" Click="DownloadStudentTemplate"
                                    Width="200" Height="35" Background="#6C757D" 
                                    Foreground="White" FontSize="14" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="statusTB" Margin="0,20,0,0"
                               Foreground="#2E8B57" FontWeight="Bold" FontSize="14"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>