<UserControl x:Class="BPRapp.Pages.MainMenuTeachers.Lessons.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Lessons"
             mc:Ignorable="d" 
              d:DesignHeight="80" d:DesignWidth="900">
    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Color="#333333" Opacity="0.15" Direction="315"/>
    </UserControl.Resources>
    <Grid Margin="5">
        <Border Background="White" CornerRadius="12" Padding="15" BorderBrush="#C5D5E5" BorderThickness="1" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Button Content="✏️" Click="EditLesson" Width="34" Height="28" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="🗑️" Click="DeleteLesson" Width="34" Height="28" Background="#F44336" Foreground="White" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Название учебного предмета:" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>
                    <TextBox x:Name="lessonTB" IsEnabled="False" Height="26" TextWrapping="Wrap" Text="" VerticalContentAlignment="Center" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1" Padding="8,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>