<Page x:Class="BPRapp.Pages.MainMenuTeachers.Lessons.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Lessons"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Добавить новый предмет" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" Margin="0,0,0,0" FontSize="19" FontFamily="MV Boli" Grid.Column="1" />
        </Grid>

        <Grid Margin="0,45,0,0" Background="White">
            <Button Content="Назад" HorizontalAlignment="Left" Click="GoBack" Foreground="White"  VerticalAlignment="Top" Width="60" Height="30" Background="CadetBlue" BorderBrush="Black" BorderThickness="1" Margin="10,10,0,0"/>
            <Label Content="Название предмета:" Margin="0,0,278,100" VerticalAlignment="Center" HorizontalAlignment="Center" Height="26"/>
            <TextBox x:Name="lessonTB" HorizontalAlignment="Center" Margin="0,0,0,50" Width="400" Height="32" Background="White" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center"/>
            <Button x:Name="BthAdd" Click="AddLesson" Content="Добавить новый предмет" HorizontalAlignment="Center" Margin="0, 30,0,0" Foreground="White" VerticalAlignment="Center" Width="200" Height="31" Background="CadetBlue" BorderBrush="Black" BorderThickness="1"/>
        </Grid>
    </Grid>
</Page>