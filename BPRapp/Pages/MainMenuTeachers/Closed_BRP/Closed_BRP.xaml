<Page x:Class="BPRapp.Pages.MainMenuTeachers.Closed_BRP.Closed_BRP"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Closed_BRP"
      mc:Ignorable="d"
      d:DesignHeight="750" d:DesignWidth="1200"
      Title="Ближайшие ВПР">

    <Page.Resources>
        <!-- 🎨 Корпоративные цвета -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <Color x:Key="White">#FFFFFF</Color>
        <Color x:Key="AccentBlue">#4A86C7</Color>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
        <!-- ✨ Тень для карточек -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" 
                          Color="#333333" Opacity="0.15" Direction="315"/>
        <!-- 🔘 Стиль кнопки -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 🔘 Стиль кнопки меню -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="{StaticResource LightBlueBrush}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource LightBlueBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 📝 Стиль TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C5D5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 🔽 Стиль ComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C5D5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ContentPresenter Content="{TemplateBinding Text}" Margin="6,0" VerticalAlignment="Center"/>
                            </Border>
                            <ToggleButton Grid.Column="1" Focusable="false"
                                        IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                        ClickMode="Press" HorizontalAlignment="Right" Width="24"
                                        Background="Transparent" BorderThickness="0">
                                <Path Data="M0,0 L4,4 L8,0 Z" Fill="{StaticResource DarkBlueBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Width="6" Height="4"/>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="{StaticResource PrimaryBlueBrush}"
                                        BorderThickness="1" CornerRadius="5" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 🔘 Стиль CheckBox -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="checkBoxBorder" Width="18" Height="18" 
                                    Background="White" BorderBrush="{StaticResource PrimaryBlueBrush}" 
                                    BorderThickness="2" CornerRadius="3">
                                <Path x:Name="checkMark" Data="M0,4 L4,8 L12,0" 
                                      Stroke="{StaticResource PrimaryBlueBrush}" 
                                      StrokeThickness="2" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!-- 🎨 Градиентный фон -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource LightBlue}" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔷 Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="White" CornerRadius="24" Width="48" Height="48" 
                        HorizontalAlignment="Left" Effect="{StaticResource CardShadow}">
                    <TextBlock Text="⏰" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Ближайшие ВПР" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="КГПАОУ Авиационный техникум имени А.Д. Швецова"
                               FontSize="12" Foreground="#E6F2FF" Margin="0,3,0,0"/>
                </StackPanel>
                <!-- Информация о пользователе -->
                <StackPanel x:Name="UserInfoPanel" Grid.Column="1" 
                            Margin="0,0,20,0" VerticalAlignment="Center" 
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="FioLbl" Text="" FontWeight="Bold" 
                               Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="ContactLbl" Text="" 
                               Foreground="#E6F2FF" FontSize="11" FontStyle="Italic"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 📋 Основное содержимое -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: Меню -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" 
                    Padding="15" Effect="{StaticResource CardShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="📌 Разделы" FontSize="16" FontWeight="Bold" 
                                   Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,15"/>
                        <Button Content="📋 Списки ВПР" Click="OpenSpiski_BPR" Style="{StaticResource MenuButton}"/>
                        <Button Content="📅 Расписание ВПР" Click="OpenRaspisanie_BPR" Style="{StaticResource MenuButton}"/>
                        <Button Content="🔒 Ближайшие ВПР" Click="OpenClosed_BRP" Style="{StaticResource MenuButton}"
                                Background="{StaticResource LightBlueBrush}" BorderBrush="{StaticResource PrimaryBlueBrush}"/>
                        <Button Content="📤 Экспорт/Импорт" Click="OpenExport" Style="{StaticResource MenuButton}"/>
                        <Button Content="🔔 Настройки уведомлений" Click="OpenNotificationSettings" Style="{StaticResource MenuButton}"/>
                        <Separator Margin="5,10" Background="{StaticResource LightBlueBrush}"/>
                        <!-- 🔹 Справочники -->
                        <TextBlock Text="📚 Справочники" FontSize="16" FontWeight="Bold" 
                                   Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,15"/>
                        <Button Content="📚 Учебные предметы" Click="OpenLessons" Style="{StaticResource MenuButton}"/>
                        <Button Content="🚪 Кабинеты" Click="OpenKabinets" Style="{StaticResource MenuButton}"/>
                        <Button Content="👥 Группы" Click="OpenGroups" Style="{StaticResource MenuButton}"/>
                        <Button Content="🏢 Отделения" Click="OpenDepartments" Style="{StaticResource MenuButton}"/>
                        <Separator Margin="5,10" Background="{StaticResource LightBlueBrush}"/>
                        <!-- 🔹 Кнопка ВЫХОД -->
                        <Button Content="🚪 Выйти из системы" Click="OpenAuthorization" Width="190" Height="45" Margin="5,5,5,15">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MenuButton}">
                                    <Setter Property="Background" Value="#FFE5E5"/>
                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFCDD2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Правая панель: Фильтры и список -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" 
                    Padding="20" Margin="20,0,0,0" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Фильтры -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <ComboBox x:Name="teacherFilterCB" Width="180" Margin="0,0,10,0" 
                                  Style="{StaticResource ModernComboBox}"
                                  DisplayMemberPath="FIO" SelectedValuePath="Id"/>
                        <ComboBox x:Name="lessonFilterCB" Width="180" Margin="0,0,10,0" 
                                  Style="{StaticResource ModernComboBox}"
                                  DisplayMemberPath="Lesson" SelectedValuePath="Id"/>
                        <ComboBox x:Name="groupFilterCB" Width="180" 
                                  Style="{StaticResource ModernComboBox}"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>

                    <!-- 🔹 Фильтры: "Мои ВПР" + "Исключить прошедшие" -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                        <!-- ✅ ДОБАВЛЕНО: Чекбокс "Исключить прошедшие ВПР" -->
                        <CheckBox x:Name="excludePastCB" Content="🚫 Исключить прошедшие ВПР из списка" 
                                  Style="{StaticResource ModernCheckBox}" 
                                  Margin="0,0,15,0" Checked="ExcludePastChanged" Unchecked="ExcludePastChanged"/>
                        <Button x:Name="myBPRBtn" Content="Мои ВПР" Width="120" 
                                Click="ToggleMyBPR" Style="{StaticResource ModernButton}"/>
                    </StackPanel>

                    <!-- Список ВПР -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="Closed_BPRParent" Background="Transparent"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>