<UserControl x:Class="BPRapp.Pages.MainMenuTeachers.Closed_BRP.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Closed_BRP"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="900">

    <UserControl.Resources>
        <!-- 🎨 Корпоративные цвета -->
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" 
                          Color="#333333" Opacity="0.15" Direction="315"/>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Основная информация -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="15"
                BorderBrush="#C5D5E5" BorderThickness="1"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Дата -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="📅 Дата" FontWeight="SemiBold" 
                               Foreground="{StaticResource DarkBlueBrush}" FontSize="12"/>
                    <TextBlock x:Name="dateTB" Text="" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Время -->
                <StackPanel Grid.Column="1" Margin="8,0">
                    <TextBlock Text="⏰ Время" FontWeight="SemiBold" 
                               Foreground="{StaticResource DarkBlueBrush}" FontSize="12"/>
                    <TextBlock x:Name="timeTB" Text="" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Студенты -->
                <StackPanel Grid.Column="2" Margin="8,0">
                    <TextBlock Text="👥 Студентов" FontWeight="SemiBold" 
                               Foreground="{StaticResource DarkBlueBrush}" FontSize="12"/>
                    <TextBlock x:Name="countTB" Text="" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Преподаватель -->
                <StackPanel Grid.Column="3" Margin="8,0">
                    <TextBlock Text="👨‍🏫 Преподаватель" FontWeight="SemiBold" 
                               Foreground="{StaticResource DarkBlueBrush}" FontSize="12"/>
                    <TextBlock x:Name="responsible_userTB" Text="" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Предмет -->
                <StackPanel Grid.Column="4" Margin="8,0,0,0">
                    <TextBlock Text="📚 Предмет" FontWeight="SemiBold" 
                               Foreground="{StaticResource DarkBlueBrush}" FontSize="12"/>
                    <TextBlock x:Name="lessonTB" Text="" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таймер обратного отсчёта -->
        <Border Grid.Row="1" Margin="0,8,0,0" Padding="10,8"
                Background="#E8F4FC" CornerRadius="8"
                BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="1">
            <Label x:Name="ClosedDate" Content=""
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{StaticResource DarkBlueBrush}"
                   HorizontalContentAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>