<Page x:Class="BPRapp.Pages.MainMenuTeachers.Spiski_BPR.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Spiski_BPR"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid>
        <Grid Background="CadetBlue" Height="45" VerticalAlignment="Top">
            <Label Content="Добавить/Изменить ВПР" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" FontSize="19" FontFamily="MV Boli"/>
        </Grid>
        <Grid Margin="0,45,0,0" Background="White">
            <Button Content="Назад" HorizontalAlignment="Left" Click="GoBack" Foreground="White" VerticalAlignment="Top" Width="60" Height="30" Background="CadetBlue" Margin="10,10,0,0"/>
            <StackPanel Margin="200, 40, 200, 0" Width="400">
                <Label Content="Дата проведения:"/>
                <DatePicker x:Name="dateTB" Margin="0,5" Height="30"/>
                <Label Content="Время начала:"/>
                <TextBox x:Name="startTimeTB" Margin="0,5" Height="30" />
                <Label Content="Время окончания:"/>
                <TextBox x:Name="endTimeTB" Margin="0,5" Height="30" />
                <Label Content="Кабинет:"/>
                <ComboBox x:Name="roomCB" Margin="0,5" Height="30" SelectedValuePath="Id"/>
                <Label Content="Группа:"/>
                <ComboBox x:Name="groupCB" Margin="0,5" Height="30" SelectedValuePath="Id"/>
                <Label Content="Ответственный преподаватель:"/>
                <ComboBox x:Name="teacherCB" Margin="0,5" Height="30" DisplayMemberPath="FIO" SelectedValuePath="Id"/>
                <Label Content="Предмет:"/>
                <ComboBox x:Name="lessonCB" Margin="0,5" Height="30" DisplayMemberPath="Lesson" SelectedValuePath="Id"/>
                <Button x:Name="BthAdd" Click="AddBPR_info" Content="Сохранить" Margin="0,20" Height="35" Background="CadetBlue" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>