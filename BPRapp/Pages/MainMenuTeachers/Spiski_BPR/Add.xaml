<Page x:Class="BPRapp.Pages.MainMenuTeachers.Spiski_BPR.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Spiski_BPR"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="950"
      Title="Добавить/Изменить ВПР">

    <Page.Resources>
        <Color x:Key="PrimaryBlue">#5B9BD5</Color>
        <Color x:Key="DarkBlue">#2E5C8A</Color>
        <Color x:Key="LightBlue">#E8F4FC</Color>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
        <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}"/>
        <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource LightBlue}"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Color="#333333" Opacity="0.15" Direction="315"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C5D5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C5D5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                <ContentPresenter Content="{TemplateBinding Text}" Margin="6,0" VerticalAlignment="Center"/>
                            </Border>
                            <ToggleButton Grid.Column="1" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" HorizontalAlignment="Right" Width="24" Background="Transparent" BorderThickness="0">
                                <Path Data="M0,0 L4,4 L8,0 Z" Fill="{StaticResource DarkBlueBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="6" Height="4"/>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="1" CornerRadius="5" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource LightBlue}" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="White" CornerRadius="24" Width="48" Height="48" HorizontalAlignment="Left" Effect="{StaticResource CardShadow}">
                    <TextBlock Text="📋" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Добавить/Изменить ВПР" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="КГПАОУ Авиационный техникум имени А.Д. Швецова" FontSize="12" Foreground="#E6F2FF" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25">
            <Border Background="White" CornerRadius="12" Padding="25" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Дата проведения" FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,6"/>
                            <DatePicker x:Name="dateTB" Height="32" BorderBrush="#C5D5E5" BorderThickness="1"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Время начала" FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,6"/>
                            <TextBox x:Name="startTimeTB" Style="{StaticResource ModernTextBox}" ToolTip="ЧЧ:ММ"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Время окончания" FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,6"/>
                            <TextBox x:Name="endTimeTB" Style="{StaticResource ModernTextBox}" ToolTip="ЧЧ:ММ"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Кабинет" FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="roomCB" Style="{StaticResource ModernComboBox}" SelectedValuePath="Id"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Группа" FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="groupCB" Style="{StaticResource ModernComboBox}" SelectedValuePath="Id"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Ответственный преподаватель" FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="teacherCB" Style="{StaticResource ModernComboBox}" DisplayMemberPath="FIO" SelectedValuePath="Id"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Предмет" FontWeight="SemiBold" Foreground="{StaticResource DarkBlueBrush}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="lessonCB" Style="{StaticResource ModernComboBox}" DisplayMemberPath="Lesson" SelectedValuePath="Id"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="25,20" BorderBrush="{StaticResource LightBlueBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="← Назад" Click="GoBack" Width="130" Height="35" Background="#6C757D" Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="BthAdd" Click="AddBPR_info" Content="💾 Сохранить" Style="{StaticResource ModernButton}" Width="180" Grid.Column="2" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Page>