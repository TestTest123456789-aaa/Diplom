<UserControl x:Class="BPRapp.Pages.MainMenuTeachers.Spiski_BPR.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BPRapp.Pages.MainMenuTeachers.Spiski_BPR"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Border BorderBrush="CadetBlue" BorderThickness="1" Background="White" CornerRadius="20" VerticalAlignment="Top" Height="165">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="5" Opacity="0.5"/>
            </Border.Effect>
            <Grid Margin="15">
                <Button Content="Открыть список" VerticalAlignment="Top" HorizontalAlignment="Left" Width="100" Height="25" Background="CadetBlue" Foreground="White" FontWeight="Bold" Click="OpenSpisok" Margin="0,24,0,0"/>
                <Button Content="Изменить" HorizontalAlignment="Left" VerticalAlignment="Top" Width="100" Height="25" BorderBrush="Green" Background="Green" Foreground="White" FontWeight="Bold" Click="EditSpisok_BPR" Margin="0,68,0,0"/>
                <Button Content="Удалить" HorizontalAlignment="Left" VerticalAlignment="Top" Width="100" Height="25" BorderBrush="#E41613" Background="#E41613" Foreground="White" FontWeight="Bold" Margin="0,110,0,0" Click="DeleteSpisok_BPR"/>

                <Grid Margin="133,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0">
                        <Label Content="Дата:" FontWeight="Bold"/>
                        <TextBox x:Name="dateTB" IsEnabled="False" Height="25" Padding="5,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0">
                        <Label Content="Время:" FontWeight="Bold"/>
                        <TextBox x:Name="timeTB" IsEnabled="False" Height="25" Padding="5,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="0">
                        <Label Content="Кабинет:" FontWeight="Bold"/>
                        <TextBox x:Name="roomTB" IsEnabled="False" Height="25" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1">
                        <Label Content="Ответственный:" FontWeight="Bold"/>
                        <TextBox x:Name="respTB" IsEnabled="False" Height="25" Padding="5,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="1">
                        <Label Content="Предмет:" FontWeight="Bold"/>
                        <TextBox x:Name="lessonTB" IsEnabled="False" Height="25" Padding="5,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="1">
                        <Label Content="Группа:" FontWeight="Bold"/>
                        <TextBox x:Name="groupTB" IsEnabled="False" Height="25" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="2">
                        <Label Content="Руков. группы:" FontWeight="Bold"/>
                        <TextBox x:Name="headTB" IsEnabled="False" Height="25" Padding="5,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="2">
                        <Label Content="Специальность:" FontWeight="Bold"/>
                        <TextBox x:Name="specTB" IsEnabled="False" Height="25" Padding="5,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="2">
                        <Label Content="Студентов:" FontWeight="Bold"/>
                        <TextBox x:Name="countTB" IsEnabled="False" Height="25" Padding="5,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>